---
import {
  formatScore,
  formatPrice,
  formatTPS,
  formatTTFT,
} from "../lib/format-utils";

interface Props {
  model: any;
}

const { model } = Astro.props;

// Provider logo mapping
const providerLogos: Record<string, string> = {
  openai: "/icons/providers/openai.svg",
  anthropic: "/icons/providers/anthropic.svg",
  claude: "/icons/providers/claude-color.svg",
  google: "/icons/providers/google.svg",
  gemini: "/icons/providers/gemini-color.svg",
  gemma: "/icons/providers/gemma-color.svg",
  meta: "/icons/providers/meta.svg",
  llama: "/icons/providers/meta.svg",
  mistral: "/icons/providers/mistral.svg",
  cohere: "/icons/providers/cohere-color.svg",
  deepseek: "/icons/providers/deepseek-color.svg",
  qwen: "/icons/providers/qwen-color.svg",
  alibaba: "/icons/providers/qwen-color.svg",
  xai: "/icons/providers/xai.svg",
  grok: "/icons/providers/grok.svg",
  nvidia: "/icons/providers/nvidia-color.svg",
  microsoft: "/icons/providers/microsoft.svg",
  moonshot: "/icons/providers/moonshot.svg",
  kimi: "/icons/providers/moonshot.svg",
  perplexity: "/icons/providers/perplexity.svg",
  bytedance: "/icons/providers/bytedance.svg",
  minimax: "/icons/providers/minimax.svg",
  zhipu: "/icons/providers/zai.svg",
  zai: "/icons/providers/zai.svg",
};

// Logos that are dark/black and need a light background in dark mode
const darkLogos = [
  "openai",
  "anthropic",
  "xai",
  "grok",
  "moonshot",
  "kimi",
  "zai",
  "zhipu",
  "meta",
  "llama",
  "perplexity",
  "bytedance",
];

const companyLower = (model.company_name ?? "").toLowerCase();
const modelNameLower = (model.name ?? "").toLowerCase();
const searchStr = `${companyLower} ${modelNameLower}`;
const normalizedSearchStr = searchStr.replace(/[^a-z0-9]+/g, "");
const matchedProvider = Object.entries(providerLogos).find(([key]) =>
  normalizedSearchStr.includes(key.replace(/[^a-z0-9]+/g, "")),
);
const providerLogo = matchedProvider?.[1];
const isDarkLogo = matchedProvider
  ? darkLogos.some((d) => normalizedSearchStr.includes(d.replace(/[^a-z0-9]+/g, "")))
  : false;
const providerName = model.company_name ?? "Unknown provider";
const providerInitials = providerName
  .split(/\s+/)
  .filter(Boolean)
  .slice(0, 2)
  .map((part: string) => part[0]?.toUpperCase())
  .join("") || "?";

// Get score color based on value (0-100 scale)
function getScoreColor(score: number | null | undefined): string {
  if (!score || score <= 0) return "score-none";
  const pct = score <= 1 ? score * 100 : score;
  if (pct >= 80) return "score-high";
  if (pct >= 60) return "score-mid";
  if (pct >= 40) return "score-low";
  return "score-poor";
}

function getScoreBg(score: number | null | undefined): string {
  if (!score || score <= 0) return "score-bg-none";
  const pct = score <= 1 ? score * 100 : score;
  if (pct >= 80) return "score-bg-high";
  if (pct >= 60) return "score-bg-mid";
  if (pct >= 40) return "score-bg-low";
  return "score-bg-poor";
}

// All benchmarks
const allBenchmarks = [
  ["MMLU Pro", model.mmlu_pro],
  ["GPQA", model.gpqa],
  ["HLE", model.hle],
  ["AIME", model.aime],
  ["LiveCodeBench", model.livecodebench],
  ["SciCode", model.scicode],
  ["Math 500", model.math_500],
];

// AA Indexes
const aaIndexes = [
  ["Intelligence", model.aa_intelligence_index],
  ["Coding", model.aa_coding_index],
  ["Math", model.aa_math_index],
];

const formatContextLength = (value: number | null | undefined): string => {
  const num = Number(value);
  if (!Number.isFinite(num) || num <= 0) return "-";
  if (num >= 1_000_000) {
    return `${(num / 1_000_000).toFixed(num % 1_000_000 === 0 ? 0 : 1)}M`;
  }
  if (num >= 1_000) return `${Math.round(num / 1_000)}K`;
  return String(num);
};

const openRouterParameters = Array.isArray(model.openrouter_supported_parameters)
  ? model.openrouter_supported_parameters
  : [];
const openRouterInputModalities = Array.isArray(model.openrouter_input_modalities)
  ? model.openrouter_input_modalities
  : [];
const openRouterOutputModalities = Array.isArray(model.openrouter_output_modalities)
  ? model.openrouter_output_modalities
  : [];
const hasOpenRouterData = Boolean(model.openrouter_id);
const openRouterCaps = [
  openRouterParameters.includes("tools") ? "Tools" : null,
  openRouterInputModalities.includes("image") ? "Vision" : null,
  openRouterOutputModalities.includes("image") ? "Image out" : null,
]
  .filter(Boolean)
  .join(", ");
const hasPositiveNumber = (value: number | null | undefined): boolean => {
  const num = Number(value);
  return Number.isFinite(num) && num > 0;
};
const pricesAreClose = (
  first: number | null | undefined,
  second: number | null | undefined,
): boolean => {
  if (!hasPositiveNumber(first) || !hasPositiveNumber(second)) return false;
  return Math.abs(Number(first) - Number(second)) < 0.001;
};
const hasOpenRouterPrice =
  hasPositiveNumber(model.openrouter_prompt_price_1m) ||
  hasPositiveNumber(model.openrouter_completion_price_1m);
const openRouterPriceMatchesAa =
  pricesAreClose(model.price_1m_input_tokens, model.openrouter_prompt_price_1m) &&
  pricesAreClose(model.price_1m_output_tokens, model.openrouter_completion_price_1m);
const showOpenRouterPricing = hasOpenRouterPrice && !openRouterPriceMatchesAa;
const effectiveContextLength = model.openrouter_context_length || model.context_window;
const dataSourceBadge = hasOpenRouterData ? "AA + OR" : "AA";
---

<div
  data-model-card
  data-model-id={model.id}
  data-model-json={JSON.stringify(model)}
  data-name={(model.name ?? "").toLowerCase()}
  data-company={(model.company_name ?? "").toLowerCase()}
  data-mmlu={Number(model.mmlu_pro) || 0}
  data-gpqa={Number(model.gpqa) || 0}
  data-hle={Number(model.hle) || 0}
  data-aime={Number(model.aime) || 0}
  data-input-price={Number(model.price_1m_input_tokens) || 0}
  data-output-price={Number(model.price_1m_output_tokens) || 0}
  data-tps={Number(model.median_output_tokens_per_second) || 0}
  class="model-card brutalist-card group px-4 py-4 text-sm stagger-item"
>
  <header class="flex items-start justify-between gap-2">
    <div class="flex items-center gap-2 min-w-0">
      {
        providerLogo ? (
          <span class={`provider-logo-frame ${isDarkLogo ? "provider-logo-frame-light" : ""}`}>
            <img
              src={providerLogo}
              alt={`${providerName} logo`}
              width="20"
              height="20"
              class="provider-logo-image"
              loading="lazy"
            />
          </span>
        ) : (
          <span class="provider-logo-frame provider-logo-fallback" aria-hidden="true">
            {providerInitials}
          </span>
        )
      }
      <div class="min-w-0">
        <h3
          class="truncate text-sm font-semibold text-text group-hover:text-foam transition-colors"
          title={model.name}
        >
          {model.name}
        </h3>
        <p class="mt-0.5 text-xs text-subtle">
          {providerName}
        </p>
      </div>
    </div>
    <div class="source-strip flex-shrink-0" title="Data coverage">
      <span>{dataSourceBadge}</span>
    </div>
  </header>

  <div class="mt-3 grid gap-2 text-[0.7rem] text-subtle sm:grid-cols-2 xl:grid-cols-3">
    <section class="card-metric-panel px-3 py-2">
      <div class="text-[0.55rem] text-muted">
        Pricing
      </div>
      <dl class="mt-1.5 space-y-0.5 text-text text-[0.65rem]">
        <div class="flex items-center justify-between">
          <dt>Input (1M)</dt>
          <dd class="font-bold">
            {formatPrice(Number(model.price_1m_input_tokens) || 0, 3)}
          </dd>
        </div>
        <div class="flex items-center justify-between">
          <dt>Output (1M)</dt>
          <dd class="font-bold">
            {formatPrice(Number(model.price_1m_output_tokens) || 0, 3)}
          </dd>
        </div>
        <div class="flex items-center justify-between">
          <dt>Blended (3:1)</dt>
          <dd class="font-bold">
            {formatPrice(Number(model.price_1m_blended_3_to_1) || 0, 3)}
          </dd>
        </div>
      </dl>
    </section>

    <section class="card-metric-panel px-3 py-2">
      <div class="text-[0.55rem] text-muted">
        Performance
      </div>
      <dl class="mt-1.5 space-y-0.5 text-text text-[0.65rem]">
        <div class="flex items-center justify-between">
          <dt>Tokens / s</dt>
          <dd class="font-bold">
            {formatTPS(model.median_output_tokens_per_second)}
          </dd>
        </div>
        <div class="flex items-center justify-between">
          <dt>TTFT (token)</dt>
          <dd class="font-bold">
            {formatTTFT(model.median_time_to_first_token_seconds)}
          </dd>
        </div>
        <div class="flex items-center justify-between">
          <dt>TTFT (answer)</dt>
          <dd class="font-bold">
            {formatTTFT(model.median_time_to_first_answer_token)}
          </dd>
        </div>
      </dl>
    </section>

    <section class="card-metric-panel px-3 py-2">
      <div class="text-[0.55rem] text-muted">
        Specs
      </div>
      <dl class="mt-1.5 space-y-0.5 text-text text-[0.65rem]">
        <div class="flex items-center justify-between">
          <dt>Context</dt>
          <dd class="font-bold">
            {formatContextLength(effectiveContextLength)}
          </dd>
        </div>
        <div class="flex items-center justify-between">
          <dt>Max output</dt>
          <dd class="font-bold">
            {formatContextLength(model.max_output_tokens)}
          </dd>
        </div>
        <div class="flex items-center justify-between">
          <dt>Source</dt>
          <dd class="font-bold">
            {dataSourceBadge}
          </dd>
        </div>
      </dl>
    </section>
  </div>

  {
    hasOpenRouterData ? (
      <section class="card-metric-panel mt-2 px-3 py-2">
        <div class="text-[0.55rem] text-muted">OpenRouter catalog</div>
        <dl class="mt-1.5 grid grid-cols-2 gap-x-4 gap-y-1 text-[0.65rem] text-text">
          <div class="flex items-center justify-between gap-2">
            <dt class="text-subtle">Tools</dt>
            <dd class="font-bold">
              {openRouterParameters.includes("tools") ? "Yes" : "No"}
            </dd>
          </div>
          <div class="flex items-center justify-between gap-2">
            <dt class="text-subtle">Route</dt>
            <dd class="font-bold">
              {model.openrouter_is_free ? "Free" : "Paid"}
            </dd>
          </div>
          {
            showOpenRouterPricing ? (
              <>
                <div class="flex items-center justify-between gap-2">
                  <dt class="text-subtle">OR input</dt>
                  <dd class="font-bold">
                    {formatPrice(model.openrouter_prompt_price_1m, 3)}
                  </dd>
                </div>
                <div class="flex items-center justify-between gap-2">
                  <dt class="text-subtle">OR output</dt>
                  <dd class="font-bold">
                    {formatPrice(model.openrouter_completion_price_1m, 3)}
                  </dd>
                </div>
              </>
            ) : null
          }
          <div class="col-span-2 flex items-center justify-between gap-3">
            <dt class="text-subtle">Modalities</dt>
            <dd class="min-w-0 truncate font-bold" title={`${openRouterInputModalities.join(", ")} to ${openRouterOutputModalities.join(", ")}`}>
              {openRouterInputModalities.join(", ") || "text"}
              {" -> "}
              {openRouterOutputModalities.join(", ") || "text"}
            </dd>
          </div>
          <div class="col-span-2 flex items-center justify-between gap-3">
            <dt class="text-subtle">Capabilities</dt>
            <dd class="min-w-0 truncate font-bold" title={openRouterCaps || "Text"}>
              {openRouterCaps || "Text"}
            </dd>
          </div>
        </dl>
      </section>
    ) : null
  }

  <!-- All Benchmarks -->
  <section
    class="card-metric-panel mt-2 px-3 py-2"
  >
    <div class="text-[0.55rem] text-muted">
      Benchmarks
    </div>
    <div class="mt-1.5 grid grid-cols-2 gap-x-4 gap-y-1 text-[0.65rem]">
      {
        allBenchmarks.map(([label, value]) => (
          <div class="flex items-center justify-between">
            <span class="text-subtle">{label}</span>
            <span class={`font-semibold ${getScoreColor(value as number)}`}>
              {formatScore(value as number)}
            </span>
          </div>
        ))
      }
    </div>
  </section>

  <!-- AA Indexes -->
  <section
    class="card-metric-panel mt-2 px-3 py-2"
  >
    <div class="text-[0.55rem] text-muted">
      AA Indexes
    </div>
    <div class="mt-1.5 grid grid-cols-3 gap-1.5">
      {
        aaIndexes.map(([label, value]) => (
          <div
            class={`border px-1.5 py-1.5 text-center ${getScoreBg(value as number)}`}
          >
            <div class="text-[0.5rem] uppercase text-muted">
              {label}
            </div>
            <div class={`text-xs font-bold ${getScoreColor(value as number)}`}>
              {formatScore(value as number)}
            </div>
          </div>
        ))
      }
    </div>
  </section>
</div>

<style>
  .model-card {
    transition:
      transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
      border-color 0.3s ease,
      box-shadow 0.3s ease;
  }

  .model-card:hover,
  .model-card:focus-visible {
    border-color: var(--love);
    box-shadow:
      0 18px 52px var(--shadow-color),
      0 0 0 1px rgba(230, 25, 25, 0.2);
  }

  .model-card:active {
    transform: translateY(-1px);
  }

  .model-card:focus-visible {
    outline: 2px solid var(--love);
    outline-offset: 2px;
  }

  .source-strip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-s);
    background: color-mix(in srgb, var(--overlay) 82%, transparent);
    min-height: 1.8rem;
    padding: 0.35rem 0.55rem;
    color: var(--subtle);
    font-family: var(--font-mono);
    font-size: 0.64rem;
    font-weight: 800;
    line-height: 1.2;
    text-align: right;
  }

  .provider-logo-frame {
    width: 1.8rem;
    height: 1.8rem;
    display: inline-flex;
    flex: 0 0 1.8rem;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-s);
    background: color-mix(in srgb, var(--overlay) 82%, transparent);
  }

  .provider-logo-frame-light {
    background: #f6f3ea;
    border-color: color-mix(in srgb, var(--love) 32%, #f6f3ea);
  }

  .provider-logo-image {
    width: 1.05rem;
    height: 1.05rem;
    object-fit: contain;
    display: block;
  }

  .provider-logo-fallback {
    color: var(--subtle);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0;
  }

  .card-metric-panel {
    border: 1px solid var(--highlight-low);
    border-radius: var(--radius-s);
    background: color-mix(in srgb, var(--overlay) 62%, transparent);
  }

  /* Keep AA index chips readable without over-saturated fills */
  .score-bg-high,
  .score-bg-mid,
  .score-bg-low,
  .score-bg-poor,
  .score-bg-none {
    border-width: 1px;
    border-style: solid;
  }

  .score-bg-high {
    background: rgba(86, 148, 159, 0.16);
    border-color: rgba(86, 148, 159, 0.45);
    color: var(--text);
  }

  .score-bg-mid {
    background: rgba(234, 157, 52, 0.16);
    border-color: rgba(234, 157, 52, 0.45);
    color: var(--text);
  }

  .score-bg-low {
    background: rgba(255, 153, 51, 0.14);
    border-color: rgba(255, 153, 51, 0.4);
    color: var(--text);
  }

  .score-bg-poor {
    background: rgba(180, 99, 122, 0.16);
    border-color: rgba(180, 99, 122, 0.45);
    color: var(--text);
  }

  .score-bg-none {
    background: rgba(130, 130, 150, 0.12);
    border-color: rgba(130, 130, 150, 0.32);
    color: var(--text);
  }

  /* Hide default details marker */
  details summary::-webkit-details-marker {
    display: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .model-card {
      transition: none;
    }
    .model-card:hover {
      transform: none;
    }
  }
</style>
