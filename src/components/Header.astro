---
interface Props {
  currentPage?: string;
}

const { currentPage = 'dashboard' } = Astro.props;
---

<header class="header">
  <div class="header-container">
    <a href="/" class="logo-link">
      <img src="/logo.png" alt="AI Stats" class="logo" width="120" height="32" />
    </a>
    
    <!-- Desktop nav -->
    <nav class="nav desktop-nav">
      <a href="/" class={`nav-item ${currentPage === 'dashboard' ? 'active' : ''}`}>Stats</a>
      <a href="/compare" class={`nav-item ${currentPage === 'compare' ? 'active' : ''}`}>Compare</a>
      <a href="/about" class={`nav-item ${currentPage === 'about' ? 'active' : ''}`}>About</a>
      <a href="/contact" class={`nav-item ${currentPage === 'contact' ? 'active' : ''}`}>Contact</a>
      <button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme" title="Toggle light/dark theme">
        <svg class="sun-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/>
        </svg>
        <svg class="moon-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
        </svg>
      </button>
    </nav>
    
    <!-- Mobile hamburger -->
    <div class="mobile-controls">
      <button id="theme-toggle-mobile" class="theme-toggle" aria-label="Toggle theme">
        <svg class="sun-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/>
        </svg>
        <svg class="moon-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
        </svg>
      </button>
      <button id="mobile-menu-toggle" class="hamburger" aria-label="Toggle menu" aria-expanded="false">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
  </div>
  
  <!-- Mobile nav overlay -->
  <div id="mobile-nav-overlay" class="mobile-nav-overlay"></div>
  <nav id="mobile-nav" class="mobile-nav" inert>
    <a href="/" class={`mobile-nav-item ${currentPage === 'dashboard' ? 'active' : ''}`} tabindex="-1">Stats</a>
    <a href="/compare" class={`mobile-nav-item ${currentPage === 'compare' ? 'active' : ''}`} tabindex="-1">Compare</a>
    <a href="/about" class={`mobile-nav-item ${currentPage === 'about' ? 'active' : ''}`} tabindex="-1">About</a>
    <a href="/contact" class={`mobile-nav-item ${currentPage === 'contact' ? 'active' : ''}`} tabindex="-1">Contact</a>
  </nav>
</header>

<style is:global>
.header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: color-mix(in srgb, var(--base) 82%, transparent);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--border-color);
  height: 56px;
  width: 100%;
  max-width: 100vw;
  overflow: visible;
  box-sizing: border-box;
}

.header-container {
  max-width: 1400px;
  height: 56px;
  margin: 0 auto;
  padding: 0 1.5rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 1rem;
  box-sizing: border-box;
}

.logo-link,
.mobile-controls {
  flex-shrink: 0;
}

.logo-link {
  text-decoration: none;
  transition: transform 0.18s ease, color 0.18s ease;
}

.logo-link:hover {
  transform: translateX(2px);
}

.logo {
  display: block;
  height: 32px;
  width: auto;
  object-fit: contain;
}

.nav {
  display: flex;
  gap: 0.25rem;
  align-items: center;
  background: color-mix(in srgb, var(--surface) 76%, transparent);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-m);
  padding: 0.2rem;
}

.nav-item {
  color: var(--subtle);
  text-decoration: none;
  font-family: var(--font-mono);
  font-weight: 800;
  padding: 0 0.85rem;
  border-radius: var(--radius-s);
  transition:
    color 0.18s ease,
    background 0.18s ease;
  font-size: 0.72rem;
  text-transform: uppercase;
  display: inline-flex;
  align-items: center;
  min-height: 36px;
  background: transparent;
  box-sizing: border-box;
}

.nav-item:hover {
  color: var(--text);
  background: var(--overlay);
}

.nav-item:active {
  transform: scale(0.97);
}

.nav-item.active {
  color: var(--text);
  background: color-mix(in srgb, var(--love) 18%, transparent);
  box-shadow: inset 0 -2px 0 var(--love);
}


/* Theme toggle */
.theme-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border: 1px solid var(--border-color);
  border-radius: var(--radius-s);
  background: transparent;
  color: var(--text);
  cursor: pointer;
  transition:
    background 0.18s ease,
    color 0.18s ease,
    border-color 0.18s ease;
}

.theme-toggle:hover {
  background: var(--love);
  border-color: var(--love);
  color: #ffffff;
}

.theme-toggle:active {
  transform: scale(0.92);
}

.theme-toggle .sun-icon { display: none; }
.theme-toggle .moon-icon { display: block; }

html.light .theme-toggle .sun-icon { display: block; }
html.light .theme-toggle .moon-icon { display: none; }

/* Mobile controls */
.mobile-controls {
  display: none;
  align-items: center;
  gap: 0.5rem;
}

/* Hamburger button */
.hamburger {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  width: 44px;
  height: 44px;
  padding: 6px;
  background: transparent;
  border: 1px solid var(--border-color);
  border-radius: var(--radius-s);
  cursor: pointer;
  gap: 4px;
  transition: all 0.2s ease;
}

.hamburger:hover {
  background: var(--overlay);
  border-color: var(--love);
}

.hamburger-line {
  width: 16px;
  height: 2px;
  background: var(--text);
  border-radius: 0;
  transition: all 0.3s ease;
}

.hamburger.open .hamburger-line:nth-child(1) {
  transform: rotate(45deg) translate(4px, 4px);
}

.hamburger.open .hamburger-line:nth-child(2) {
  opacity: 0;
}

.hamburger.open .hamburger-line:nth-child(3) {
  transform: rotate(-45deg) translate(4px, -4px);
}

/* Mobile nav overlay */
.mobile-nav-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.72);
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s ease, visibility 0.3s ease;
  z-index: 998;
}

.mobile-nav-overlay.open {
  opacity: 1;
  visibility: visible;
}

/* Mobile nav */
.mobile-nav {
  position: fixed;
  top: 56px;
  right: 0;
  width: min(280px, calc(100vw - 2rem));
  background: var(--surface);
  border-left: 1px solid var(--border-color);
  border-bottom: 1px solid var(--border-color);
  border-radius: 0 0 0 var(--radius-m);
  padding: 0;
  display: none;
  flex-direction: column;
  gap: 0.5rem;
  transform: translateX(100%);
  transition: transform 0.3s ease;
  z-index: 999;
  box-shadow: -20px 24px 80px var(--shadow-color);
}

.mobile-nav.open {
  transform: translateX(0);
}

.mobile-nav-item {
  color: var(--subtle);
  text-decoration: none;
  font-family: var(--font-mono);
  font-weight: 800;
  padding: 1rem;
  border-bottom: 1px solid var(--border-color);
  border-radius: var(--radius-s);
  font-size: 0.85rem;
  text-transform: uppercase;
  transition:
    color 0.18s ease,
    background 0.18s ease;
}

.mobile-nav-item:hover {
  color: #ffffff;
  background: var(--overlay);
}

.mobile-nav-item.active {
  color: var(--text);
  background: color-mix(in srgb, var(--love) 18%, transparent);
  box-shadow: inset 3px 0 0 var(--love);
}

@media (max-width: 640px) {
  .header-container {
    width: 100%;
    max-width: 100%;
    padding: 0 0.75rem;
  }
  .desktop-nav {
    display: none;
  }
  .mobile-controls {
    display: flex;
    margin-left: auto;
    z-index: 101;
  }
  .mobile-nav {
    display: flex;
  }
}
</style>

<script is:inline src="/header.js" defer></script>
