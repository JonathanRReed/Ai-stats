---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-glow"></div>
  <div class="footer-container">
    <div class="footer-brand">
      <img src="/logo-footer.png" alt="AI Stats" class="footer-logo" width="140" height="36" />
      <span class="footer-tagline">Open-source AI model comparison tool</span>
    </div>

    <div class="footer-center">
      <span class="footer-label">Related work</span>
      <div class="footer-links">
        <a
          href="https://ai-news.helloworldfirm.com"
          class="footer-link"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg
            class="link-icon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 12h10"
            ></path>
          </svg>
          AI News
        </a>
        <a
          href="https://ai-dragrace.jonathanrreed.com"
          class="footer-link"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg
            class="link-icon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
          AI Drag Race
        </a>
        <a
          href="https://jonathanrreed.com"
          class="footer-link"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg
            class="link-icon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M12 2a14.5 14.5 0 000 20 14.5 14.5 0 000-20M2 12h20"
            ></path>
          </svg>
          Portfolio
        </a>
        <a href="/contact" class="footer-link">
          <svg
            class="link-icon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M4 4h16v16H4z"></path>
            <path d="m22 6-10 7L2 6"></path>
          </svg>
          Contact
        </a>
        <a href="/privacy" class="footer-link">
          <svg
            class="link-icon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
          </svg>
          Privacy
        </a>
      </div>
    </div>

    <div class="footer-credits" aria-label="Data sources">
      <span class="footer-label">Data sources</span>
      <div class="source-list">
        <a
          href="https://artificialanalysis.ai/"
          target="_blank"
          rel="noopener noreferrer"
          class="source-card source-card-wide"
        >
          <span class="source-logo source-logo-aa">
            <img
              src="/icons/Icon + Artificial Analysis - Horizontal SVG.svg"
              alt="Artificial Analysis"
              loading="lazy"
              width="32"
              height="24"
            />
          </span>
          <span class="source-copy">
            <strong>Artificial Analysis</strong>
            <small>Pricing, AA benchmarks, speed metrics</small>
          </span>
        </a>
        <a
          href="https://epoch.ai/benchmarks"
          target="_blank"
          rel="noopener noreferrer"
          class="source-card"
        >
          <span class="source-logo">
            <img src="/icons/epochaidata.svg" alt="Epoch AI" loading="lazy" width="32" height="32" />
          </span>
          <span class="source-copy">
            <strong>Epoch AI</strong>
            <small>Benchmarking Hub runs</small>
          </span>
        </a>
        <a
          href="https://openrouter.ai/docs/api-reference/models/get-models"
          target="_blank"
          rel="noopener noreferrer"
          class="source-card"
        >
          <span class="source-logo source-logo-openrouter">
            <img src="/icons/openrouter.svg" alt="Model routing catalog" loading="lazy" width="32" height="32" />
          </span>
          <span class="source-copy">
            <strong>OpenRouter</strong>
            <small>Catalog, context, route metadata</small>
          </span>
        </a>
      </div>
      <span class="footer-copyright"
        >&copy; {currentYear} Created by Jonathan R Reed.</span
      >
    </div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    width: 100%;
    background: var(--base);
    border-top: 1px solid var(--border-color);
    padding: 5rem 1.5rem 2.5rem;
    overflow: hidden;
  }

  .footer-glow {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: min(900px, 90vw);
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--love), transparent);
    opacity: 0.65;
  }

  .footer-container {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: center;
    gap: 2rem;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .footer-logo {
    display: block;
    height: 36px;
    width: auto;
    object-fit: contain;
  }

  .footer-tagline {
    font-size: 0.75rem;
    color: var(--muted);
    font-family: var(--font-mono);
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .footer-center {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .footer-label {
    font-size: 0.65rem;
    font-family: var(--font-mono);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0;
    color: var(--muted);
  }

  .footer-links {
    display: flex;
    gap: 1px;
    flex-wrap: wrap;
    justify-content: center;
    background: color-mix(in srgb, var(--surface) 82%, transparent);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-m);
    padding: 0.2rem;
  }

  .footer-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 44px;
    padding: 0.6rem 1rem;
    background: transparent;
    border: 0;
    border-radius: var(--radius-s);
    color: var(--text);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .footer-link:hover {
    background: color-mix(in srgb, var(--love) 18%, transparent);
    color: var(--text);
    transform: translateY(-1px);
    box-shadow: none;
  }

  .link-icon {
    width: 14px;
    height: 14px;
    opacity: 0.7;
  }

  .footer-link:hover .link-icon {
    opacity: 1;
  }

  .footer-credits {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0.625rem;
    font-size: 0.75rem;
    color: var(--muted);
    font-family: var(--font-mono);
    text-transform: none;
  }

  .source-list {
    display: grid;
    min-width: min(420px, 100%);
    gap: 0.4rem;
  }

  .source-card {
    display: grid;
    grid-template-columns: 42px minmax(0, 1fr);
    align-items: center;
    gap: 0.75rem;
    min-height: 54px;
    padding: 0.45rem 0.65rem;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-s);
    background: color-mix(in srgb, var(--surface) 86%, transparent);
    color: var(--text);
    text-decoration: none;
    transition:
      border-color 0.2s ease,
      background 0.2s ease,
      transform 0.2s ease;
  }

  .source-card:hover {
    border-color: color-mix(in srgb, var(--love) 55%, var(--border-color));
    background: color-mix(in srgb, var(--love) 10%, var(--surface));
    transform: translateY(-1px);
  }

  .source-logo {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 36px;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-s);
    background: #ffffff;
    color: #111318;
    overflow: hidden;
  }

  .source-logo img {
    display: block;
    max-width: 74%;
    max-height: 74%;
    object-fit: contain;
  }

  .source-logo-aa img {
    max-width: 92%;
    max-height: 64%;
  }

  .source-logo-openrouter {
    background: color-mix(in srgb, var(--text) 92%, #ffffff);
    color: var(--base);
  }

  .source-logo-openrouter img {
    filter: invert(1);
  }

  .source-copy {
    display: flex;
    min-width: 0;
    flex-direction: column;
    gap: 0.125rem;
  }

  .source-copy strong {
    color: var(--text);
    font-size: 0.74rem;
    font-weight: 900;
    line-height: 1.1;
    text-transform: uppercase;
  }

  .source-copy small {
    color: var(--muted);
    font-size: 0.66rem;
    line-height: 1.25;
    text-transform: none;
  }

  .external-link {
    color: var(--text);
    text-decoration: none;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .external-link:hover {
    color: var(--love);
    text-decoration: underline;
  }

  .footer-copyright {
    opacity: 0.7;
    font-size: 0.7rem;
    text-align: right;
  }

  /* Tablet layout */
  @media (max-width: 900px) {
    .footer-container {
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }

    .footer-center {
      grid-column: 1 / -1;
      order: -1;
    }

    .footer-credits {
      align-items: stretch;
    }
  }

  /* Mobile layout */
  @media (max-width: 600px) {
    .footer {
      padding: 2.5rem 1rem 1.5rem;
    }

    .footer-container {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 1.5rem;
    }

    .footer-brand {
      align-items: center;
    }

    .footer-center {
      order: 0;
    }

    .footer-credits {
      align-items: stretch;
    }

    .footer-links {
      gap: 0.5rem;
    }

    .footer-link {
      padding: 0.5rem 0.875rem;
      font-size: 0.75rem;
    }

    .source-list {
      min-width: 0;
    }

    .footer-copyright {
      text-align: center;
    }
  }

  :global(html.light) .footer {
    background: var(--base);
    border-top: 1px solid var(--border-color);
  }

  :global(html.light) .footer-glow {
    background: var(--love);
  }

  :global(html.light) .footer-tagline,
  :global(html.light) .footer-label,
  :global(html.light) .footer-credits {
    color: var(--muted);
  }

  :global(html.light) .footer-link {
    background: var(--base);
    color: var(--text);
  }

  :global(html.light) .footer-link:hover {
    background: var(--love);
    color: #ffffff;
    box-shadow: none;
  }

  :global(html.light) .source-card {
    background: var(--base);
  }

  :global(html.light) .source-card:hover {
    background: color-mix(in srgb, var(--love) 12%, var(--base));
  }

  :global(html.light) .external-link {
    color: var(--text);
  }

  :global(html.light) .external-link:hover {
    color: var(--love);
  }
</style>
