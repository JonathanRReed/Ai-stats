---
import {
  getModels,
  getHydratedEpochModels,
  getEpochBenchmarks,
  getEpochBenchmarkRuns,
  getPublicCatalogModels,
  enrichModelsWithPublicCatalogData,
} from "../lib/supabase";
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import ScrollToTop from "./ScrollToTop.astro";
import { formatScore, formatPrice } from "../lib/format-utils";
import {
  VALUABLE_FREE_BENCHMARK_SLUGS,
  EPOCH_BENCHMARK_LABELS,
  AA_BENCHMARK_ATTRIBUTION,
  getEpochBenchmarkAttribution,
  getEpochBenchmarksWithRuns,
  getEpochBenchmarkLabel,
} from "../lib/benchmark-catalog";
import { getPublicEpochSnapshot } from "../lib/epoch-snapshot";
import ModelCard from "./ModelCard.astro";

const [baseModels, initialEpochBenchmarks, initialEpochRuns, publicCatalogs] =
  await Promise.all([
    getModels(),
    getEpochBenchmarks(),
    getEpochBenchmarkRuns(),
    getPublicCatalogModels(),
  ]);
const {
  openRouterModels,
  huggingFaceModels,
  liteLlmModels,
  openRouterUsageRankings,
  openRouterProviders,
  openRouterModelCount,
  openRouterEmbeddingModels,
  openRouterEndpointSummaries,
} = publicCatalogs;
const initialEpochModels = await getHydratedEpochModels(initialEpochRuns);
const publicEpochSnapshot = await getPublicEpochSnapshot();
const usePublicEpochSnapshot =
  publicEpochSnapshot &&
  publicEpochSnapshot.epochRuns.length > initialEpochRuns.length;
const epochBenchmarks = usePublicEpochSnapshot
  ? publicEpochSnapshot.epochBenchmarks
  : initialEpochBenchmarks;
const epochRuns = usePublicEpochSnapshot
  ? publicEpochSnapshot.epochRuns
  : initialEpochRuns;
const epochModels = usePublicEpochSnapshot
  ? publicEpochSnapshot.epochModels
  : initialEpochModels;
const models = enrichModelsWithPublicCatalogData(baseModels, publicCatalogs);

const epochBenchmarksWithRuns = getEpochBenchmarksWithRuns(
  epochBenchmarks,
  epochRuns,
);
const preferredEpochBenchmarkSlugs = [...VALUABLE_FREE_BENCHMARK_SLUGS];

// Get benchmark name mapping
const epochBenchmarkNames: Record<string, string> = {};
epochBenchmarks.forEach((b) => {
  epochBenchmarkNames[b.slug] = getEpochBenchmarkLabel(b);
});
const benchmarkAttributions: Record<string, any> = {
  mmlu_pro: AA_BENCHMARK_ATTRIBUTION,
  gpqa: AA_BENCHMARK_ATTRIBUTION,
  hle: AA_BENCHMARK_ATTRIBUTION,
  aime: AA_BENCHMARK_ATTRIBUTION,
  scicode: AA_BENCHMARK_ATTRIBUTION,
  math_500: AA_BENCHMARK_ATTRIBUTION,
  livecodebench: AA_BENCHMARK_ATTRIBUTION,
  aa_math_index: AA_BENCHMARK_ATTRIBUTION,
  aa_coding_index: AA_BENCHMARK_ATTRIBUTION,
  aa_intelligence_index: AA_BENCHMARK_ATTRIBUTION,
};
epochBenchmarksWithRuns.forEach((benchmark) => {
  benchmarkAttributions[`epoch_${benchmark.slug}`] = getEpochBenchmarkAttribution(
    benchmark,
    epochRuns,
  );
});

const AA_TOP_AVERAGE_KEYS = [
  "mmlu_pro",
  "gpqa",
  "hle",
  "aime",
  "scicode",
  "math_500",
  "livecodebench",
  "aa_math_index",
  "aa_coding_index",
  "aa_intelligence_index",
] as const;

const toPercentScore = (value: number | null | undefined): number | null => {
  const score = Number(value);
  if (!Number.isFinite(score) || score <= 0) return null;
  return score <= 1 ? score * 100 : score;
};

const averageScore = (values: Array<number | null | undefined>): number | null => {
  const normalized = values
    .map((value) => toPercentScore(value))
    .filter((value): value is number => value !== null);
  if (!normalized.length) return null;
  return normalized.reduce((sum, value) => sum + value, 0) / normalized.length;
};

const normalizeModelVersion = (value: string | null | undefined): string =>
  String(value || "")
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, " ")
    .trim();

const buildEpochModelAliases = (model: {
  model_version?: string | null;
  model_name?: string | null;
  display_name?: string | null;
}): Set<string> => {
  const aliases = new Set<string>();
  [model.model_version, model.model_name, model.display_name].forEach((value) => {
    const normalized = normalizeModelVersion(value);
    if (!normalized) return;
    aliases.add(normalized);
    aliases.add(normalized.replace(/\s+/g, ""));
  });
  return aliases;
};

const getEpochAverageForModel = (model: {
  model_version?: string | null;
  model_name?: string | null;
  display_name?: string | null;
}): number | null => {
  const aliases = buildEpochModelAliases(model);
  if (!aliases.size) return null;

  const scores = epochRuns
    .filter(
      (run) => {
        const normalizedRun = normalizeModelVersion(run.model_version);
        if (!normalizedRun || Number(run.score) <= 0) return false;
        return (
          aliases.has(normalizedRun) ||
          aliases.has(normalizedRun.replace(/\s+/g, ""))
        );
      },
    )
    .map((run) => toPercentScore(Number(run.score)))
    .filter((score): score is number => score !== null);
  if (!scores.length) return null;
  return scores.reduce((sum, score) => sum + score, 0) / scores.length;
};

// Top epoch model by ECI score
const topEciModel =
  [...epochModels]
    .filter((m) => Number(m.eci_score) > 0)
    .sort((a, b) => Number(b.eci_score) - Number(a.eci_score))[0] ?? null;
const topEciAverageScore = topEciModel
  ? getEpochAverageForModel(topEciModel)
  : null;

const validModels = models.filter((model: any) => {
  const inputPrice = Number(model.price_1m_input_tokens);
  const outputPrice = Number(model.price_1m_output_tokens);
  return inputPrice > 0 && outputPrice > 0;
});

const totalModels = validModels.length;
const INITIAL_VISIBLE_MODELS = Math.min(8, totalModels);
const initialModels = validModels.slice(0, INITIAL_VISIBLE_MODELS);
const avgInputPrice =
  validModels.reduce(
    (sum: number, m: any) => sum + Number(m.price_1m_input_tokens),
    0,
  ) / (totalModels || 1);
const avgOutputPrice =
  validModels.reduce(
    (sum: number, m: any) => sum + Number(m.price_1m_output_tokens),
    0,
  ) / (totalModels || 1);

// Combined benchmark configs - AA benchmarks first, then Epoch benchmarks
const benchmarkConfigs = [
  // AA Benchmarks
  { key: "mmlu_pro", label: "MMLU Pro", source: "aa" },
  { key: "gpqa", label: "GPQA", source: "aa" },
  { key: "hle", label: "HLE", source: "aa" },
  { key: "aime", label: "AIME", source: "aa" },
  { key: "scicode", label: "SciCode", source: "aa" },
  { key: "math_500", label: "Math 500", source: "aa" },
  { key: "livecodebench", label: "LiveCodeBench", source: "aa" },
  { key: "aa_math_index", label: "AA Math Index", source: "aa" },
  { key: "aa_coding_index", label: "AA Coding Index", source: "aa" },
  {
    key: "aa_intelligence_index",
    label: "AA Intelligence Index",
    source: "aa",
  },
  ...epochBenchmarksWithRuns.map((benchmark) => ({
    key: `epoch_${benchmark.slug}`,
    label: `${getEpochBenchmarkLabel(benchmark)} (Epoch)`,
    source: "epoch" as const,
  })),
];

// Build top models for AA benchmarks
const topByBenchmark: Record<string, any[]> = {};

// AA benchmarks - from validModels
benchmarkConfigs
  .filter((c) => c.source === "aa")
  .forEach(({ key }) => {
    const list = [...validModels]
      .filter((m: any) => m[key] && Number(m[key]) > 0)
      .sort((a: any, b: any) => Number(b[key]) - Number(a[key]))
      .slice(0, 5);
    topByBenchmark[key] = list;
  });

epochBenchmarksWithRuns.forEach((benchmark) => {
  const slug = benchmark.slug;
  const runs = epochRuns
    .filter((r) => r.benchmark_slug === slug && r.score !== null)
    .sort((a, b) => (b.score ?? 0) - (a.score ?? 0))
    .slice(0, 5)
    .map((r) => ({
      name: r.model_version.replace(/_/g, " ").replace(/-/g, " "),
      company_name: r.organization,
      score: r.score,
      isEpoch: true,
    }));
  topByBenchmark[`epoch_${slug}`] = runs;
});

const topAaAverageModel =
  [...validModels]
    .map((model: any) => ({
      model,
      avgScore: averageScore(
        AA_TOP_AVERAGE_KEYS.map((metricKey) => Number(model[metricKey])),
      ),
    }))
    .filter((entry) => entry.avgScore !== null)
    .sort((a, b) => Number(b.avgScore) - Number(a.avgScore))[0] ??
  null;

const cheapestBlendedModel =
  [...validModels]
    .filter((m: any) => Number(m.price_1m_blended_3_to_1) > 0)
    .sort(
      (a: any, b: any) =>
        Number(a.price_1m_blended_3_to_1) - Number(b.price_1m_blended_3_to_1),
    )[0] ?? null;

const openRouterToolModels = openRouterModels.filter((model) =>
  model.supported_parameters.includes("tools"),
);
const openRouterVisionModels = openRouterModels.filter((model) =>
  model.input_modalities.includes("image"),
);
const matchedOpenRouterModels = models.filter((model) => model.openrouter_id);
const matchedHuggingFaceModels = models.filter((model) => model.hf_model_id);
const matchedLiteLlmModels = models.filter((model) => model.litellm_model_id);
const topHuggingFaceMatch =
  [...matchedHuggingFaceModels].sort(
    (a, b) => Number(b.hf_downloads ?? 0) - Number(a.hf_downloads ?? 0),
  )[0] ?? null;
const topLiteLlmContextMatch =
  [...matchedLiteLlmModels].sort(
    (a, b) =>
      Number(b.litellm_max_input_tokens ?? 0) -
      Number(a.litellm_max_input_tokens ?? 0),
  )[0] ?? null;
const matchedOpenRouterUsageModels = models.filter(
  (model) => Number(model.openrouter_usage_tokens ?? 0) > 0,
);
const matchedOpenRouterEndpointModels = models.filter(
  (model) => Number(model.openrouter_endpoint_provider_count ?? 0) > 0,
);
const topOpenRouterUsageModel =
  [...matchedOpenRouterUsageModels].sort(
    (a, b) =>
      Number(b.openrouter_usage_tokens ?? 0) -
      Number(a.openrouter_usage_tokens ?? 0),
  )[0] ?? null;
const openRouterProviderUsage = openRouterUsageRankings.reduce(
  (summary, ranking) => {
    const provider = ranking.provider ?? "unknown";
    if (!summary[provider]) {
      summary[provider] = {
        tokens: 0,
        requests: 0,
        toolCalls: 0,
      };
    }
    summary[provider].tokens += Number(ranking.total_tokens) || 0;
    summary[provider].requests += Number(ranking.request_count) || 0;
    summary[provider].toolCalls += Number(ranking.tool_calls) || 0;
    return summary;
  },
  {} as Record<
    string,
    {
      tokens: number;
      requests: number;
      toolCalls: number;
    }
  >,
);
const openRouterProviderSummary = Object.values(
  openRouterModels.reduce(
    (summary, model) => {
      const provider = model.author_slug ?? "unknown";
      const usage = openRouterProviderUsage[provider];
      if (!summary[provider]) {
        summary[provider] = {
          provider,
          total: 0,
          tools: 0,
          vision: 0,
          maxContext: 0,
          usageTokens: 0,
          usageRequests: 0,
          usageToolCalls: 0,
        };
      }
      summary[provider].total += 1;
      summary[provider].usageTokens = usage?.tokens ?? summary[provider].usageTokens;
      summary[provider].usageRequests =
        usage?.requests ?? summary[provider].usageRequests;
      summary[provider].usageToolCalls =
        usage?.toolCalls ?? summary[provider].usageToolCalls;
      if (model.supported_parameters.includes("tools")) {
        summary[provider].tools += 1;
      }
      if (model.input_modalities.includes("image")) {
        summary[provider].vision += 1;
      }
      summary[provider].maxContext = Math.max(
        summary[provider].maxContext,
        Number(model.context_length) || 0,
      );
      return summary;
    },
    {} as Record<
      string,
      {
        provider: string;
        total: number;
        tools: number;
        vision: number;
        maxContext: number;
        usageTokens: number;
        usageRequests: number;
        usageToolCalls: number;
      }
    >,
  ),
)
  .sort((a, b) => b.usageTokens - a.usageTokens || b.total - a.total)
  .slice(0, 6);

const openRouterRankOptions = [
  { key: "usage", label: "Usage tokens" },
  { key: "requests", label: "Usage requests" },
  { key: "catalog", label: "Catalog coverage" },
  { key: "tools", label: "Tool-ready routes" },
  { key: "vision", label: "Vision coverage" },
  { key: "context", label: "Max context" },
  { key: "input_price", label: "Lowest input price" },
  { key: "output_price", label: "Lowest output price" },
] as const;

const clientOpenRouterModels = openRouterModels.map((model) => ({
  openrouter_id: model.openrouter_id,
  canonical_slug: model.canonical_slug,
  author_slug: model.author_slug,
  model_slug: model.model_slug,
  name: model.name,
  context_length: model.context_length,
  prompt_price_1m: model.prompt_price_1m,
  completion_price_1m: model.completion_price_1m,
  supported_parameters: model.supported_parameters,
  input_modalities: model.input_modalities,
  output_modalities: model.output_modalities,
  is_free: model.is_free,
}));
const clientHuggingFaceModels = huggingFaceModels.map((model) => ({
  model_id: model.model_id,
  author: model.author,
  downloads: model.downloads,
  likes: model.likes,
  pipeline_tag: model.pipeline_tag,
  library_name: model.library_name,
  last_modified: model.last_modified,
  tags: model.tags,
}));
const clientLiteLlmModels = liteLlmModels.map((model) => ({
  model_id: model.model_id,
  provider: model.provider,
  mode: model.mode,
  max_input_tokens: model.max_input_tokens,
  max_output_tokens: model.max_output_tokens,
  input_price_1m: model.input_price_1m,
  output_price_1m: model.output_price_1m,
  supports_vision: model.supports_vision,
  supports_function_calling: model.supports_function_calling,
  supports_reasoning: model.supports_reasoning,
  supports_prompt_caching: model.supports_prompt_caching,
  supports_system_messages: model.supports_system_messages,
  supports_web_search: model.supports_web_search,
}));
const clientOpenRouterUsageRankings = openRouterUsageRankings.map((ranking) => ({
  model_permaslug: ranking.model_permaslug,
  variant_permaslug: ranking.variant_permaslug,
  provider: ranking.provider,
  variant: ranking.variant,
  rank: ranking.rank,
  total_tokens: ranking.total_tokens,
  request_count: ranking.request_count,
  tool_calls: ranking.tool_calls,
  tool_call_errors: ranking.tool_call_errors,
  usage_share: ranking.usage_share,
  change: ranking.change,
  date: ranking.date,
}));
const clientOpenRouterEndpointSummaries = openRouterEndpointSummaries.map((summary) => ({
  openrouter_id: summary.openrouter_id,
  provider_count: summary.provider_count,
  providers: summary.providers,
  quantizations: summary.quantizations,
  max_context_length: summary.max_context_length,
  min_prompt_price_1m: summary.min_prompt_price_1m,
  min_completion_price_1m: summary.min_completion_price_1m,
}));

const formatContextLength = (value: number | null | undefined): string => {
  const num = Number(value);
  if (!Number.isFinite(num) || num <= 0) return "-";
  if (num >= 1_000_000) {
    return `${(num / 1_000_000).toFixed(num % 1_000_000 === 0 ? 0 : 1)}M`;
  }
  if (num >= 1_000) {
    return `${Math.round(num / 1_000)}K`;
  }
  return String(num);
};

const formatCompactNumber = (value: number | null | undefined): string => {
  const num = Number(value);
  if (!Number.isFinite(num) || num <= 0) return "-";
  return new Intl.NumberFormat("en", {
    notation: "compact",
    maximumFractionDigits: 1,
  }).format(num);
};

// Helper for score coloring
function getScoreClass(score: number | null | undefined): string {
  if (!score || score <= 0) return "score-none";
  const pct = score <= 1 ? score * 100 : score;
  if (pct >= 80) return "score-high";
  if (pct >= 60) return "score-mid";
  if (pct >= 40) return "score-low";
  return "score-poor";
}
---

<div class="site-shell min-h-screen bg-base text-text">
  <Header currentPage="dashboard" />

  <main
    class="telemetry-main mx-auto flex w-full max-w-7xl flex-col gap-14 px-4 pb-24 pt-10 md:gap-16 md:px-6 md:pt-16"
  >
    <h1 class="sr-only">AI model pricing and benchmark dashboard</h1>
    <section
      aria-label="Operational metrics"
      class="telemetry-bento grid-flow-dense fade-in-section stagger-container"
    >
      <article class="bento-cell stagger-item">
        <span class="console-label">Tracked models</span>
        <data id="hero-model-count" value={totalModels}>{totalModels}</data>
        <p>Priced models from the Artificial Analysis feed.</p>
      </article>
      <article class="bento-cell stagger-item">
        <span class="console-label">AA average leader</span>
        <output id="top-mmlu-name">
          {topAaAverageModel ? topAaAverageModel.model.name : "-"}
        </output>
        <samp id="top-mmlu-score">
          {
            topAaAverageModel
              ? `${formatScore(topAaAverageModel.avgScore)} avg`
              : "N/A"
          }
        </samp>
      </article>
      <article class="bento-cell stagger-item">
        <span class="console-label">Cheapest blended</span>
        <output id="cheapest-blended-name">
          {cheapestBlendedModel ? cheapestBlendedModel.name : "-"}
        </output>
        <samp id="cheapest-blended-price">
          {
            cheapestBlendedModel
              ? formatPrice(
                  Number(cheapestBlendedModel.price_1m_blended_3_to_1) || 0,
                  3,
                )
              : ""
          }
        </samp>
      </article>
      <article class="bento-cell stagger-item">
        <span class="console-label">Epoch signal</span>
        <output id="top-eci-name">
          {
            topEciModel
              ? topEciModel.display_name || topEciModel.model_name
              : "-"
          }
        </output>
        <samp id="top-eci-score">
          {
            topEciAverageScore !== null
              ? `${topEciAverageScore.toFixed(1)}% avg`
              : topEciModel && Number(topEciModel.eci_score) > 0
                ? `${Number(topEciModel.eci_score).toFixed(1)} ECI`
                : "N/A"
          }
        </samp>
      </article>
      <article class="bento-cell stagger-item">
        <span class="console-label">Epoch coverage</span>
        <data id="epoch-models-count" value={epochModels.length}>
          {epochModels.length}
        </data>
        <p>
          <span id="epoch-benchmarks-count">
            {epochBenchmarksWithRuns.length} benchmarks
          </span>
          /
          <span id="epoch-runs-count">{epochRuns.length} benchmark runs</span>
        </p>
      </article>
      <article class="bento-cell stagger-item">
        <span class="console-label">Token averages</span>
        <div class="metric-pair">
          <span>
            <small>Input</small>
            <data id="summary-avg-input">{formatPrice(avgInputPrice, 3)}</data>
          </span>
          <span>
            <small>Output</small>
            <data id="summary-avg-output">{formatPrice(avgOutputPrice, 3)}</data>
          </span>
        </div>
        <p>Mean price per 1M tokens across priced models.</p>
      </article>
    </section>

    {
      openRouterModels.length ||
      huggingFaceModels.length ||
      liteLlmModels.length ||
      openRouterUsageRankings.length ? (
        <section
          aria-label="Public catalog collections"
          class="openrouter-panel fade-in-section"
        >
          <header class="openrouter-header">
            <div>
              <p class="console-label">Public catalog sources</p>
              <h2>Public catalog data</h2>
            </div>
            <div class="openrouter-actions">
              <label for="openrouter-rank-metric">Rank by</label>
              <div class="openrouter-select-wrap">
                <select id="openrouter-rank-metric" class="openrouter-rank-select">
                  {openRouterRankOptions.map((option) => (
                    <option value={option.key}>{option.label}</option>
                  ))}
                </select>
              </div>
              <a
                href="https://huggingface.co/models"
                target="_blank"
                rel="noopener noreferrer"
                class="toolbar-control px-3 py-2 text-[0.7rem] font-bold uppercase text-text"
              >
                Hugging Face
              </a>
            </div>
          </header>
          <div class="openrouter-grid">
            <div class="openrouter-stats" aria-label="Public catalog totals">
              <dl>
                <div>
                  <dt>OR models</dt>
                  <dd>{openRouterModelCount?.count ?? openRouterModels.length}</dd>
                </div>
                <div>
                  <dt>OR routes</dt>
                  <dd>{openRouterModels.length}</dd>
                </div>
                <div>
                  <dt>Providers</dt>
                  <dd>{openRouterProviders.length}</dd>
                </div>
                <div>
                  <dt>Embeddings</dt>
                  <dd>{openRouterEmbeddingModels.length}</dd>
                </div>
                <div>
                  <dt>HF matched</dt>
                  <dd>{matchedHuggingFaceModels.length}</dd>
                </div>
                <div>
                  <dt>LiteLLM matched</dt>
                  <dd>{matchedLiteLlmModels.length}</dd>
                </div>
                <div>
                  <dt>OR matched</dt>
                  <dd>{matchedOpenRouterModels.length}</dd>
                </div>
                <div>
                  <dt>OR usage</dt>
                  <dd>{matchedOpenRouterUsageModels.length}</dd>
                </div>
                <div>
                  <dt>Route detail</dt>
                  <dd>{matchedOpenRouterEndpointModels.length}</dd>
                </div>
              </dl>
              <p>
                Public metadata from OpenRouter, Hugging Face, and LiteLLM adds
                availability, provider directory data, embeddings, usage, context,
                route pricing, endpoint coverage, and capability checks. Benchmark
                scores remain AA and Epoch.
              </p>
            </div>
            <div class="openrouter-table" aria-label="Public catalog provider leaderboard">
              <div class="openrouter-table-meta">
                <span id="openrouter-board-title">Provider coverage</span>
                <small id="openrouter-board-note">OpenRouter route catalog ranking</small>
              </div>
              <div class="openrouter-table-head" aria-hidden="true">
                <span>Provider</span>
                <span>Leader</span>
                <span>Usage</span>
                <span>Models</span>
                <span>Max ctx</span>
              </div>
              <ul id="openrouter-provider-board">
                {openRouterProviderSummary.map((provider) => (
                  <li>
                    <button
                      type="button"
                      class="openrouter-provider-row"
                      data-openrouter-provider={provider.provider}
                      data-openrouter-provider-query={provider.provider}
                    >
                      <span class="openrouter-model" title={provider.provider}>
                        {provider.provider}
                      </span>
                      <span class="openrouter-leader">{formatCompactNumber(provider.usageRequests)} requests</span>
                      <span class="openrouter-score">{formatCompactNumber(provider.usageTokens)}</span>
                      <span>{provider.total}</span>
                      <span>{formatContextLength(provider.maxContext)}</span>
                    </button>
                  </li>
                ))}
              </ul>
            </div>
            <div class="openrouter-long-context">
              <span class="console-label">Useful catalog signals</span>
              <strong>{topHuggingFaceMatch?.name ?? topLiteLlmContextMatch?.name ?? "-"}</strong>
              <span>
                {topHuggingFaceMatch
                  ? `${Number(topHuggingFaceMatch.hf_downloads ?? 0).toLocaleString()} HF downloads`
                  : `${formatContextLength(topLiteLlmContextMatch?.litellm_max_input_tokens)} LiteLLM context`}
              </span>
              <small>
                {topLiteLlmContextMatch
                  ? `Top OpenRouter usage match: ${topOpenRouterUsageModel?.name ?? "-"}, ${topOpenRouterUsageModel ? formatCompactNumber(topOpenRouterUsageModel.openrouter_usage_tokens) : "-"} tokens`
                  : `${openRouterToolModels.length} OpenRouter tool-ready routes, ${openRouterVisionModels.length} vision routes, ${openRouterEndpointSummaries.length} endpoint checks`}
              </small>
            </div>
          </div>
        </section>
      ) : null
    }

    <!-- Leaderboard -->
    <section id="leaderboard" aria-label="Leaderboard" class="space-y-4 fade-in-section scroll-mt-28">
      <div class="brutalist-card">
        <header
          class="relative z-20 flex flex-col gap-3 border-b border-highlight-low/80 px-4 py-4 md:flex-row md:items-center md:justify-between md:px-6"
        >
          <div>
            <h2 class="text-base font-semibold text-text md:text-lg">
              Leaderboard
            </h2>
            <p class="text-[0.7rem] text-subtle md:text-xs">
              Switch metrics to see different top-5 rankings.
            </p>
          </div>
          <div class="leaderboard-controls relative z-30">
            <a
              id="leaderboard-compare-link"
              href="/compare"
              class="toolbar-control px-3 py-1 text-[0.7rem] font-bold uppercase text-text"
            >
              Open compare
            </a>
            <label
              for="leaderboard-metric"
              class="text-[0.7rem] font-medium text-subtle"
            >
              Metric
            </label>
            <select
              id="leaderboard-metric"
              class="toolbar-control relative z-30 pointer-events-auto px-3 py-1 text-[0.7rem] font-bold uppercase text-text active:translate-y-px"
            >
              {
                benchmarkConfigs.map(({ key, label }) => (
                  <option value={key} selected={key === "mmlu_pro"}>
                    {label}
                  </option>
                ))
              }
            </select>
            <div
              class="benchmark-picker"
              data-benchmark-picker
              data-target-select="leaderboard-metric"
              hidden
            >
              <button
                type="button"
                class="benchmark-picker-trigger"
                aria-haspopup="listbox"
                aria-expanded="false"
              >
                <span class="benchmark-picker-kicker">Selected metric</span>
                <span class="benchmark-picker-value">MMLU Pro</span>
              </button>
              <div class="benchmark-picker-popover" hidden>
                <label class="sr-only" for="leaderboard-benchmark-search">
                  Search benchmarks
                </label>
                <input
                  id="leaderboard-benchmark-search"
                  class="benchmark-picker-search"
                  type="search"
                  placeholder="Search benchmarks..."
                  autocomplete="off"
                />
                <div
                  class="benchmark-picker-list"
                  role="listbox"
                  aria-label="Leaderboard metric"
                ></div>
              </div>
            </div>
          </div>
        </header>
        <p
          id="leaderboard-attribution"
          class="border-t border-highlight-low/50 px-4 py-2 text-[0.7rem] uppercase tracking-[0.08em] text-subtle md:px-6"
        >
          Source:
          <a
            href={benchmarkAttributions.mmlu_pro.sourceUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-text underline decoration-highlight-med/70 underline-offset-4"
          >
            {benchmarkAttributions.mmlu_pro.sourceName}
          </a>
        </p>

        <div
          class="relative z-10 space-y-3 px-4 pb-4 pt-3 md:px-6 md:pb-6"
          id="leaderboard-panels"
        >
          {
            benchmarkConfigs.map(({ key, source }) => {
              const list = topByBenchmark[key] ?? [];
              if (!list.length) return null;
              const isEpoch = source === "epoch";
              // For epoch benchmarks, score is stored in model.score; for AA, it's model[key]
              const getScore = (m: any) =>
                isEpoch ? Number(m.score) || 0 : Number(m[key]) || 0;
              const maxScore = Math.max(...list.map(getScore));

              return (
                <div
                  data-metric={key}
                  class="overflow-hidden border border-highlight-low/60"
                  hidden={key !== "mmlu_pro"}
                >
                  <ul class="divide-y divide-highlight-low/40">
                    {list.map((model: any, index: number) => {
                      const score = getScore(model);
                      const barWidth =
                        maxScore > 0 ? (score / maxScore) * 100 : 0;
                      const rankColors = [
                        "bg-[rgba(230,25,25,0.18)] border-l-[var(--love)]",
                        "bg-highlight-low border-l-highlight-high",
                        "bg-highlight-low border-l-highlight-med",
                        "bg-transparent border-l-highlight-med",
                        "bg-transparent border-l-highlight-med",
                      ];

                      return (
                        <li class="relative overflow-hidden transition-colors hover:bg-highlight-low/40">
                          <button
                            type="button"
                            class="leaderboard-row relative block w-full overflow-hidden text-left"
                            data-leaderboard-row
                            data-model-json={isEpoch ? undefined : JSON.stringify(model)}
                            data-compare-url={isEpoch ? `/compare?metric=${key}&model=${encodeURIComponent(model.name ?? "")}` : undefined}
                          >
                            {/* Background bar */}
                            <div
                              class={`pointer-events-none absolute inset-y-0 left-0 ${rankColors[index]} border-l-4`}
                              style={`width: ${barWidth}%`}
                            />

                            <div class="relative grid grid-cols-[2.5rem_1fr_auto] items-center gap-4 px-4 py-3.5">
                              {/* Rank */}
                              <div class="flex items-center justify-center">
                                {index === 0 ? (
                                  <div class="flex h-8 w-8 items-center justify-center border border-love bg-love text-sm font-bold text-white">
                                    1
                                  </div>
                                ) : index === 1 ? (
                                  <div class="flex h-8 w-8 items-center justify-center border border-highlight-high bg-highlight-low text-sm font-bold text-text">
                                    2
                                  </div>
                                ) : index === 2 ? (
                                  <div class="flex h-8 w-8 items-center justify-center border border-highlight-med bg-overlay text-sm font-bold text-text">
                                    3
                                  </div>
                                ) : (
                                  <div class="flex h-7 w-7 items-center justify-center border border-highlight-med bg-highlight-low text-xs font-semibold text-subtle">
                                    {index + 1}
                                  </div>
                                )}
                              </div>

                              {/* Model info */}
                              <div class="min-w-0">
                                <div class="flex items-center gap-2">
                                  <span
                                    class={`truncate font-semibold ${index === 0 ? "text-text" : "text-text/90"}`}
                                    title={model.name}
                                  >
                                    {model.name}
                                  </span>
                                </div>
                                <div class="mt-0.5 text-[0.7rem] text-subtle">
                                  {model.company_name ?? "Unknown provider"}
                                </div>
                              </div>

                              {/* Score */}
                              <div
                                class={`text-right font-mono text-lg font-bold ${index === 0 ? "score-high" : index < 3 ? "text-text" : "text-subtle"}`}
                              >
                                {isEpoch
                                  ? `${(score * 100).toFixed(1)}%`
                                  : formatScore(model[key])}
                              </div>
                            </div>
                          </button>
                        </li>
                      );
                    })}
                  </ul>
                </div>
              );
            })
          }
        </div>
      </div>
    </section>

    <!-- All models -->
    <section id="model-browser" aria-label="All models" class="space-y-4 fade-in-section">
