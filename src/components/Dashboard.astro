    .openrouter-actions label {
      align-self: auto;
    }

    .openrouter-select-wrap {
      min-width: 0;
    }

    .openrouter-header .toolbar-control {
      width: 100%;
    }

    .openrouter-stats dl {
      grid-template-columns: 1fr;
    }

    .openrouter-table {
      overflow-x: auto;
    }

    .openrouter-table-head,
    .openrouter-provider-row {
      min-width: 38rem;
    }

    :global(.openrouter-provider-row) {
      min-width: 38rem;
    }

    .telemetry-bento {
      grid-template-columns: 1fr;
    }
  }
</style>

<script is:inline define:vars={{ clientOpenRouterModels }}>
  window.__aistatsOpenRouterModels = clientOpenRouterModels;
</script>

<script>
  // @ts-nocheck
  if (typeof window !== "undefined") {
    const PAGE_SIZE = 20;
    const AA_BENCHMARKS = [
      { key: "mmlu_pro", label: "MMLU Pro", source: "aa" },
      { key: "gpqa", label: "GPQA", source: "aa" },
      { key: "hle", label: "HLE", source: "aa" },
      { key: "aime", label: "AIME", source: "aa" },
      { key: "scicode", label: "SciCode", source: "aa" },
      { key: "math_500", label: "Math 500", source: "aa" },
      { key: "livecodebench", label: "LiveCodeBench", source: "aa" },
      { key: "aa_math_index", label: "AA Math Index", source: "aa" },
      { key: "aa_coding_index", label: "AA Coding Index", source: "aa" },
      {
        key: "aa_intelligence_index",
        label: "AA Intelligence Index",
        source: "aa",
      },
    ];
    const AA_TOP_AVERAGE_KEYS = [
      "mmlu_pro",
      "gpqa",
      "hle",
      "aime",
      "scicode",
      "math_500",
      "livecodebench",
      "aa_math_index",
      "aa_coding_index",
      "aa_intelligence_index",
    ];

    const grid = document.getElementById("models-grid");
    const tableBody = document.getElementById("models-table-body");
    const tableContainer = document.getElementById("models-table-container");
    const searchInput = document.getElementById("model-search");
    const sortSelect = document.getElementById("model-sort");
    const sortDirectionSelect = document.getElementById("model-sort-direction");
    const loadMoreBtn = document.getElementById("load-more-models");
    const visibleCountEl = document.getElementById("visible-model-count");
    const totalCountEl = document.getElementById("total-models-count");
    const heroCountEl = document.getElementById("hero-model-count");
    const summaryAvgInputEl = document.getElementById("summary-avg-input");
    const summaryAvgOutputEl = document.getElementById("summary-avg-output");
    const topMmluNameEl = document.getElementById("top-mmlu-name");
    const topMmluScoreEl = document.getElementById("top-mmlu-score");
    const topEciNameEl = document.getElementById("top-eci-name");
    const topEciScoreEl = document.getElementById("top-eci-score");
    const cheapestNameEl = document.getElementById("cheapest-blended-name");
    const cheapestPriceEl = document.getElementById("cheapest-blended-price");
    const epochModelsCountEl = document.getElementById("epoch-models-count");
    const epochRunsCountEl = document.getElementById("epoch-runs-count");
    const metricSelect = document.getElementById("leaderboard-metric");
    const leaderboardPanels = document.getElementById("leaderboard-panels");
    const leaderboardCompareLink = document.getElementById(
      "leaderboard-compare-link",
    );
    const openRouterRankSelect = document.getElementById(
      "openrouter-rank-metric",
    );
    const openRouterProviderBoard = document.getElementById(
      "openrouter-provider-board",
    );
    const openRouterBoardTitle = document.getElementById(
      "openrouter-board-title",
    );
    const openRouterBoardNote = document.getElementById("openrouter-board-note");
    const emptyState = document.getElementById("empty-state");
    const viewCardsBtn = document.getElementById("view-cards");
    const viewTableBtn = document.getElementById("view-table");

    let currentVisible = PAGE_SIZE;
    let matchedTotal = 0;
    let currentView = "cards";
    let focusedCardIndex = -1;

    const updateLeaderboardCompareLink = () => {
      if (!leaderboardCompareLink || !metricSelect) return;
      const metric = metricSelect.value || "mmlu_pro";
      leaderboardCompareLink.setAttribute(
        "href",
        `/compare?metric=${encodeURIComponent(metric)}`,
      );
    };

    const escapeHtml = (value) =>
      String(value ?? "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");

    const toDisplayName = (value, fallback = "-") => {
      const str = String(value ?? "").trim();
      return str || fallback;
    };

    const formatScore = (score) => {
      const num = Number(score);
      if (!Number.isFinite(num) || num <= 0) return "N/A";
      const pct = num <= 1 ? num * 100 : num;
      return `${pct.toFixed(1)}%`;
    };

    const formatPrice = (price, decimals = 3) => {
      const num = Number(price);
      if (!Number.isFinite(num) || num <= 0) return "-";
      const factor = Math.pow(10, decimals);
      const truncated = Math.trunc(num * factor) / factor;
      return `$${truncated.toFixed(decimals)}`;
    };

    const formatTps = (tps) => {
      const num = Number(tps);
      if (!Number.isFinite(num) || num <= 0) return "-";
      return num.toFixed(1);
    };

    const formatTtft = (ttft) => {
      const num = Number(ttft);
      if (!Number.isFinite(num) || num <= 0) return "-";
      return `${num.toFixed(2)}s`;
    };

    const formatContextLength = (value) => {
      const num = Number(value);
      if (!Number.isFinite(num) || num <= 0) return "-";
      if (num >= 1000000) {
        return `${(num / 1000000).toFixed(num % 1000000 === 0 ? 0 : 1)}M`;
      }
      if (num >= 1000) return `${Math.round(num / 1000)}K`;
      return String(num);
    };

    const normalizeOpenRouterKey = (value) =>
      String(value || "")
        .toLowerCase()
        .replace(/^(openai|anthropic|google|meta|mistral|moonshotai|moonshot|alibaba|qwen|xai|deepseek|minimax|nvidia|cohere|perplexity):\s*/i, "")
        .replace(/\([^)]*\)/g, " ")
        .replace(/:free$/i, "")
        .replace(/[^a-z0-9]+/g, " ")
        .trim();

    const openRouterLookup = (() => {
      const lookup = new Map();
      (window.__aistatsOpenRouterModels || []).forEach((model) => {
        const candidates = [
          model.openrouter_id,
          model.openrouter_id?.split("/").slice(1).join("/"),
          model.canonical_slug,
          model.model_slug,
          model.name,
          model.name?.includes(":") ? model.name.split(":").slice(1).join(":") : model.name,
        ];
        candidates.forEach((candidate) => {
          const normalized = normalizeOpenRouterKey(candidate);
          if (!normalized) return;
          if (!lookup.has(normalized)) lookup.set(normalized, model);
          const compact = normalized.replace(/\s+/g, "");
          if (!lookup.has(compact)) lookup.set(compact, model);
        });
      });
      return lookup;
    })();

    const enrichWithOpenRouter = (models) =>
      (models || []).map((model) => {
        const candidates = [
          model.slug,
          model.name,
          String(model.name || "").replace(/\([^)]*\)/g, ""),
          model.company_name && model.name
            ? `${model.company_name} ${model.name}`
            : null,
          model.creator_slug && model.slug
            ? `${model.creator_slug} ${model.slug}`
            : null,
        ];
        const match = candidates
          .flatMap((candidate) => {
            const normalized = normalizeOpenRouterKey(candidate);
            return normalized ? [normalized, normalized.replace(/\s+/g, "")] : [];
          })
          .map((key) => openRouterLookup.get(key))
          .find(Boolean);
        if (!match) return model;
        return {
          ...model,
          openrouter_id: match.openrouter_id,
          openrouter_name: match.name,
          openrouter_context_length: match.context_length,
          openrouter_prompt_price_1m: match.prompt_price_1m,
          openrouter_completion_price_1m: match.completion_price_1m,
          openrouter_supported_parameters: match.supported_parameters || [],
          openrouter_input_modalities: match.input_modalities || [],
          openrouter_output_modalities: match.output_modalities || [],
          openrouter_is_free: match.is_free,
        };
      });

    const getScoreClass = (score) => {
      const num = Number(score);
      if (!Number.isFinite(num) || num <= 0) return "score-none";
      const pct = num <= 1 ? num * 100 : num;
      if (pct >= 80) return "score-high";
      if (pct >= 60) return "score-mid";
      if (pct >= 40) return "score-low";
      return "score-poor";
    };

    const toPercentScore = (score) => {
      const num = Number(score);
      if (!Number.isFinite(num) || num <= 0) return null;
      return num <= 1 ? num * 100 : num;
    };

    const getAverageScore = (values) => {
      const normalized = values
        .map((value) => toPercentScore(value))
        .filter((value) => value !== null);
      if (!normalized.length) return null;
      return normalized.reduce((sum, value) => sum + value, 0) / normalized.length;
    };

    const normalizeModelVersion = (value) =>
      String(value || "")
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, " ")
        .trim();

    const buildEpochModelAliases = (model) => {
      const aliases = new Set();
      [model?.model_version, model?.model_name, model?.display_name].forEach(
        (value) => {
          const normalized = normalizeModelVersion(value);
          if (!normalized) return;
          aliases.add(normalized);
          aliases.add(normalized.replace(/\s+/g, ""));
        },
      );
      return aliases;
    };

    const getEpochAverageForModel = (model, epochRuns) => {
      const aliases = buildEpochModelAliases(model);
      if (!aliases.size) return null;

      const scores = (epochRuns ?? [])
        .filter(
          (run) => {
            const normalizedRun = normalizeModelVersion(run.model_version);
            if (!normalizedRun || Number(run.score) <= 0) return false;
            return (
              aliases.has(normalizedRun) ||
              aliases.has(normalizedRun.replace(/\s+/g, ""))
            );
          },
        )
        .map((run) => toPercentScore(run.score))
        .filter((value) => value !== null);
      if (!scores.length) return null;
      return scores.reduce((sum, value) => sum + value, 0) / scores.length;
    };

    const sortAttrMap = {
      mmlu: "mmlu",
      gpqa: "gpqa",
      hle: "hle",
      aime: "aime",
      inputPrice: "inputPrice",
      outputPrice: "outputPrice",
      tps: "tps",
    };

    const getCards = () =>
      Array.from(document.querySelectorAll("[data-model-card]"));
    const getTableRows = () =>
      Array.from(document.querySelectorAll("[data-table-row]"));

    const getValidModels = (models) =>
      (models ?? []).filter((model) => {
        const input = Number(model.price_1m_input_tokens);
        const output = Number(model.price_1m_output_tokens);
        return input > 0 && output > 0;
      });

    const getOpenRouterProvider = (model) => {
      const idProvider = String(model?.openrouter_id || "")
        .split("/")[0]
        .trim();
      return idProvider || String(model?.author_slug || "unknown").trim() || "unknown";
    };

    const OPENROUTER_PROVIDER_SEARCH = {
      "meta-llama": "llama",
      "mistralai": "mistral",
      "moonshotai": "kimi",
      "x-ai": "grok",
      "qwen": "qwen",
      "google": "google",
      "openai": "openai",
      "anthropic": "anthropic",
      "deepseek": "deepseek",
      "minimax": "minimax",
    };

    const OPENROUTER_RANK_METRICS = [
      { key: "catalog", label: "Catalog coverage", note: "OpenRouter catalog", kind: "catalog", direction: "desc" },
      { key: "tools", label: "Tool-ready routes", note: "OpenRouter supported parameters", kind: "tools", direction: "desc" },
      { key: "vision", label: "Vision coverage", note: "OpenRouter input modalities", kind: "vision", direction: "desc" },
      { key: "context", label: "Max context", note: "OpenRouter context windows", kind: "context", direction: "desc" },
      { key: "input_price", label: "Lowest input price", note: "OpenRouter route pricing", kind: "input_price", direction: "asc" },
      { key: "output_price", label: "Lowest output price", note: "OpenRouter route pricing", kind: "output_price", direction: "asc" },
    ];

    const getOpenRouterRankMetric = (key) =>
      OPENROUTER_RANK_METRICS.find((metric) => metric.key === key) ??
      OPENROUTER_RANK_METRICS[0];

    const getProviderSearchValue = (provider) =>
      OPENROUTER_PROVIDER_SEARCH[String(provider || "").toLowerCase()] ||
      String(provider || "").replace(/-/g, " ");

    const buildOpenRouterProviderGroups = () => {
      const groups = new Map();
      const ensureGroup = (provider) => {
        const key = String(provider || "unknown").trim() || "unknown";
        if (!groups.has(key)) {
          groups.set(key, {
            provider: key,
            total: 0,
            tools: 0,
            vision: 0,
            maxContext: 0,
            maxContextModel: null,
            catalogModels: [],
          });
        }
        return groups.get(key);
      };

      (window.__aistatsOpenRouterModels || []).forEach((model) => {
        const provider = getOpenRouterProvider(model);
        const group = ensureGroup(provider);
        const context = Number(model?.context_length) || 0;
        group.catalogModels.push(model);
        group.total += 1;
        if ((model?.supported_parameters || []).includes("tools")) group.tools += 1;
        if ((model?.input_modalities || []).includes("image")) group.vision += 1;
        if (context > group.maxContext) {
          group.maxContext = context;
          group.maxContextModel = model;
        }
      });

      return Array.from(groups.values());
    };

    const getBestOpenRouterPriceModel = (models, key) => {
      const priceKey =
        key === "output_price" ? "completion_price_1m" : "prompt_price_1m";
      const candidates = (models || [])
        .map((model) => ({
          model,
          score: Number(model?.[priceKey]),
        }))
        .filter((entry) => Number.isFinite(entry.score) && entry.score > 0);
      if (!candidates.length) return null;
      candidates.sort((a, b) => a.score - b.score);
      return candidates[0];
    };

    const renderOpenRouterProviderLeaderboard = () => {
      if (!openRouterRankSelect || !openRouterProviderBoard) return;

      const metric = getOpenRouterRankMetric(openRouterRankSelect.value);
      const groups = buildOpenRouterProviderGroups();
      const rows = groups
        .map((group) => {
          const base = {
            ...group,
            leaderName:
              group.maxContextModel?.name ||
              `${group.tools} tool-ready, ${group.vision} vision`,
            displayScore: String(group.total),
            scoreValue: group.total,
            model: null,
          };

          if (metric.kind === "tools") {
            return {
              ...base,
              leaderName: `${group.vision} vision routes`,
              displayScore: String(group.tools),
              scoreValue: group.tools,
            };
          }

          if (metric.kind === "vision") {
            return {
              ...base,
              leaderName: `${group.tools} tool-ready routes`,
              displayScore: String(group.vision),
              scoreValue: group.vision,
            };
          }

          if (metric.kind === "context") {
            return {
              ...base,
              leaderName: group.maxContextModel?.name || "No context data",
              displayScore: formatContextLength(group.maxContext),
              scoreValue: group.maxContext,
            };
          }

          if (metric.kind === "input_price" || metric.kind === "output_price") {
            const best = getBestOpenRouterPriceModel(
              group.catalogModels,
              metric.kind,
            );
            if (!best) {
              return {
                ...base,
                leaderName: "No route price",
                displayScore: "N/A",
                scoreValue: Number.POSITIVE_INFINITY,
              };
            }
            return {
              ...base,
              leaderName: toDisplayName(best.model?.name),
              displayScore: formatPrice(best.score, 3),
              scoreValue: best.score,
            };
          }

          return base;
        })
        .filter((row) => Number.isFinite(row.scoreValue))
        .sort((a, b) =>
          metric.direction === "asc"
            ? a.scoreValue - b.scoreValue
            : b.scoreValue - a.scoreValue,
        )
        .slice(0, 8);

      if (openRouterBoardTitle) openRouterBoardTitle.textContent = metric.label;
      if (openRouterBoardNote) openRouterBoardNote.textContent = metric.note;

      openRouterProviderBoard.innerHTML = rows
        .map((row) => {
          const provider = escapeHtml(row.provider);
          const leaderName = escapeHtml(row.leaderName);
          const modelPayload = row.model
            ? ` data-model-json="${escapeHtml(JSON.stringify(row.model))}"`
            : "";
          const providerQuery = escapeHtml(getProviderSearchValue(row.provider));
          return `
            <li>
              <button
                type="button"
                class="openrouter-provider-row"
                data-openrouter-provider="${provider}"
                data-openrouter-provider-query="${providerQuery}"
                ${modelPayload}
              >
                <span class="openrouter-model" title="${provider}">${provider}</span>
                <span class="openrouter-leader" title="${leaderName}">${leaderName}</span>
                <span class="openrouter-score">${escapeHtml(row.displayScore)}</span>
                <span>${row.total}</span>
                <span>${formatContextLength(row.maxContext)}</span>
              </button>
            </li>
          `;
        })
        .join("");
      bindOpenRouterProviderRows();
    };

    const openOpenRouterProviderRow = (row) => {
      if (row.dataset.modelJson) {
        openModelDrawerFromElement(row);
        return;
      }
      const query = row.dataset.openrouterProviderQuery;
      if (!query || !searchInput) return;
      searchInput.value = query;
      applySearch(true);
      setView("cards");
      document.getElementById("model-browser")?.scrollIntoView({
        behavior: "smooth",
        block: "start",
      });
    };

    const bindOpenRouterProviderRows = () => {
      document.querySelectorAll("[data-openrouter-provider]").forEach((row) => {
        if (!(row instanceof HTMLElement)) return;
        if (row.dataset.providerBound === "true") return;
        row.dataset.providerBound = "true";
        row.addEventListener("click", () => openOpenRouterProviderRow(row));
        row.addEventListener("keydown", (event) => {
          if (event.key !== "Enter" && event.key !== " ") return;
          event.preventDefault();
          openOpenRouterProviderRow(row);
        });
      });
    };

    const getVisibleCards = () =>
      getCards().filter((card) => card.style.display !== "none");

    const updateModelCounts = (models) => {
      const count = models.length;
      if (heroCountEl) heroCountEl.textContent = String(count);
      if (totalCountEl) totalCountEl.textContent = String(count);
    };

    const updateSummaryStats = (models) => {
      const total = models.length || 1;
      const avgInput =
        models.reduce(
          (sum, m) => sum + (Number(m.price_1m_input_tokens) || 0),
          0,
        ) / total;
      const avgOutput =
        models.reduce(
          (sum, m) => sum + (Number(m.price_1m_output_tokens) || 0),
          0,
        ) / total;
      if (summaryAvgInputEl)
        summaryAvgInputEl.textContent = formatPrice(avgInput, 3);
      if (summaryAvgOutputEl)
        summaryAvgOutputEl.textContent = formatPrice(avgOutput, 3);
    };

    const updateTopStrip = (models, epochModels, epochRuns) => {
      const topAaAverageModel =
        [...models]
          .map((model) => ({
            model,
            avgScore: getAverageScore(
              AA_TOP_AVERAGE_KEYS.map((metricKey) => model?.[metricKey]),
            ),
          }))
          .filter((entry) => entry.avgScore !== null)
          .sort((a, b) => Number(b.avgScore) - Number(a.avgScore))[0] ?? null;

      const topEciModel =
        [...(epochModels ?? [])]
          .filter((model) => Number(model?.eci_score) > 0)
          .sort((a, b) => Number(b.eci_score) - Number(a.eci_score))[0] ?? null;
      const topEpochAverage = topEciModel
        ? getEpochAverageForModel(topEciModel, epochRuns)
        : null;

      const cheapestBlended =
        [...models]
          .filter((m) => Number(m.price_1m_blended_3_to_1) > 0)
          .sort(
            (a, b) =>
              Number(a.price_1m_blended_3_to_1) -
              Number(b.price_1m_blended_3_to_1),
          )[0] ?? null;

      if (topMmluNameEl)
        topMmluNameEl.textContent = topAaAverageModel
          ? toDisplayName(topAaAverageModel.model?.name)
          : "-";
      if (topMmluScoreEl)
        topMmluScoreEl.textContent = topAaAverageModel
          ? `${formatScore(topAaAverageModel.avgScore)} avg`
          : "N/A";
      if (topEciNameEl)
        topEciNameEl.textContent = topEciModel
          ? toDisplayName(topEciModel.display_name || topEciModel.model_name)
          : "-";
      if (topEciScoreEl)
        topEciScoreEl.textContent =
          topEpochAverage !== null
            ? `${topEpochAverage.toFixed(1)}% avg`
            : topEciModel && Number(topEciModel.eci_score) > 0
              ? `${Number(topEciModel.eci_score).toFixed(1)} ECI`
              : "N/A";
      if (cheapestNameEl)
        cheapestNameEl.textContent = cheapestBlended
          ? toDisplayName(cheapestBlended.name)
          : "-";
      if (cheapestPriceEl) {
        cheapestPriceEl.textContent = cheapestBlended
          ? formatPrice(cheapestBlended.price_1m_blended_3_to_1, 3)
          : "";
      }

      if (Array.isArray(epochRuns) && epochRunsCountEl) {
        epochRunsCountEl.textContent = `${epochRuns.length} benchmark runs`;
      }
      if (Array.isArray(epochRuns) && epochModelsCountEl) {
        const modelCount = Array.isArray(epochModels) && epochModels.length
          ? epochModels.length
          : new Set(
              epochRuns
                .map((run) => String(run.model_version || "").trim())
                .filter(Boolean),
            ).size;
        epochModelsCountEl.textContent = String(modelCount);
      }
    };

    const buildTopByBenchmark = (models, epochBenchmarks, epochRuns) => {
      const topByBenchmark = {};
      const aaConfigs = [];
      const epochConfigs = [];

      AA_BENCHMARKS.forEach((config) => {
        const list = [...models]
          .filter((model) => Number(model[config.key]) > 0)
          .sort((a, b) => Number(b[config.key]) - Number(a[config.key]))
          .slice(0, 5);
        if (!list.length) return;
        topByBenchmark[config.key] = list;
        aaConfigs.push(config);
      });

      epochBenchmarks.forEach((benchmark) => {
        const key = `epoch_${benchmark.slug}`;
        const list = epochRuns
          .filter(
            (run) =>
              run.benchmark_slug === benchmark.slug && run.score !== null,
          )
          .sort((a, b) => Number(b.score) - Number(a.score))
          .slice(0, 5)
          .map((run) => ({
            name: String(run.model_version || "")
              .replace(/_/g, " ")
              .replace(/-/g, " "),
            company_name: run.organization ?? "Unknown provider",
            score: Number(run.score) || 0,
          }));
        if (!list.length) return;
        topByBenchmark[key] = list;
        epochConfigs.push({
          key,
          label: `${benchmark.name} (Epoch)`,
          source: "epoch",
        });
      });

      return {
        benchmarkConfigs: [...aaConfigs, ...epochConfigs],
        topByBenchmark,
      };
    };

    const renderLeaderboard = (models, epochBenchmarks, epochRuns) => {
      if (!metricSelect || !leaderboardPanels) return;

      const selectedMetric = metricSelect.value || "mmlu_pro";
      const { benchmarkConfigs, topByBenchmark } = buildTopByBenchmark(
        models,
        epochBenchmarks ?? [],
        epochRuns ?? [],
      );

      metricSelect.innerHTML = benchmarkConfigs
        .map(
          (config) =>
            `<option value="${escapeHtml(config.key)}">${escapeHtml(config.label)}</option>`,
        )
        .join("");

      const fallbackMetric = benchmarkConfigs[0]?.key ?? "mmlu_pro";
      metricSelect.value = benchmarkConfigs.some(
        (config) => config.key === selectedMetric,
      )
        ? selectedMetric
        : fallbackMetric;

      leaderboardPanels.innerHTML = benchmarkConfigs
        .map((config) => {
          const list = topByBenchmark[config.key] ?? [];
          if (!list.length) return "";

          const isEpoch = config.source === "epoch";
          const getScore = (model) =>
            isEpoch ? Number(model.score) || 0 : Number(model[config.key]) || 0;
          const formatBenchmarkScore = (score) => {
            if (!Number.isFinite(score) || score <= 0) return "N/A";
            if (!isEpoch) return formatScore(score);
            const pct = score <= 1 ? score * 100 : score;
            return `${pct.toFixed(1)}%`;
          };
          const maxScore = Math.max(...list.map(getScore), 0);
          const rankColors = [
            "bg-[rgba(230,25,25,0.18)] border-l-[var(--love)]",
            "bg-highlight-low border-l-highlight-high",
            "bg-highlight-low border-l-highlight-med",
            "bg-transparent border-l-highlight-med",
            "bg-transparent border-l-highlight-med",
          ];

          const rows = list
            .map((model, index) => {
              const score = getScore(model);
              const barWidth = maxScore > 0 ? (score / maxScore) * 100 : 0;
              const scoreText = formatBenchmarkScore(score);
              const name = escapeHtml(toDisplayName(model.name));
              const company = escapeHtml(
                toDisplayName(model.company_name, "Unknown provider"),
              );
              const modelName = toDisplayName(model.name);
              const rowAction = isEpoch
                ? `data-compare-url="/compare?metric=${encodeURIComponent(config.key)}&model=${encodeURIComponent(modelName)}"`
                : `data-model-json="${escapeHtml(JSON.stringify(model))}"`;
              const ariaLabel = isEpoch
                ? `Open ${modelName} in compare`
                : `Open ${modelName} details`;
              const rankBadge =
                index === 0
                  ? '<div class="flex h-8 w-8 items-center justify-center border border-love bg-love text-sm font-bold text-white">1</div>'
                  : index === 1
                    ? '<div class="flex h-8 w-8 items-center justify-center border border-highlight-high bg-highlight-low text-sm font-bold text-text">2</div>'
                    : index === 2
                      ? '<div class="flex h-8 w-8 items-center justify-center border border-highlight-med bg-overlay text-sm font-bold text-text">3</div>'
                      : `<div class="flex h-7 w-7 items-center justify-center border border-highlight-med bg-highlight-low text-xs font-semibold text-subtle">${index + 1}</div>`;

              return `
                <li class="relative overflow-hidden transition-colors hover:bg-highlight-low/40">
                  <button type="button" class="leaderboard-row relative block w-full overflow-hidden text-left" data-leaderboard-row ${rowAction} aria-label="${escapeHtml(ariaLabel)}">
                    <div class="pointer-events-none absolute inset-y-0 left-0 ${rankColors[index]} border-l-4" style="width: ${barWidth}%"></div>
                    <div class="relative grid grid-cols-[2.5rem_1fr_auto] items-center gap-4 px-4 py-3.5">
                      <div class="flex items-center justify-center">${rankBadge}</div>
                      <div class="min-w-0">
                        <div class="flex items-center gap-2">
                          <span class="truncate font-semibold ${index === 0 ? "text-text" : "text-text/90"}" title="${name}">${name}</span>
                        </div>
                        <div class="mt-0.5 text-[0.7rem] text-subtle">${company}</div>
                      </div>
                      <div class="text-right font-mono text-lg font-bold ${index === 0 ? "score-high" : index < 3 ? "text-text" : "text-subtle"}">${scoreText}</div>
                    </div>
                  </button>
                </li>
              `;
            })
            .join("");

          const hiddenAttr = config.key === metricSelect.value ? "" : " hidden";
          return `
            <div data-metric="${escapeHtml(config.key)}" class="overflow-hidden border border-highlight-low/60"${hiddenAttr}>
              <ul class="divide-y divide-highlight-low/40">${rows}</ul>
            </div>
          `;
        })
        .join("");

      // Keep metric select and panel set in lockstep.
      const panelKeys = new Set(
        Array.from(document.querySelectorAll("[data-metric]"))
          .map((el) => el.getAttribute("data-metric"))
          .filter(Boolean),
      );
      Array.from(metricSelect.options).forEach((option) => {
        if (!panelKeys.has(option.value)) option.remove();
      });
      if (!panelKeys.has(metricSelect.value)) {
        metricSelect.value = metricSelect.options[0]?.value ?? "mmlu_pro";
      }
      updateLeaderboardCompareLink();

      Array.from(document.querySelectorAll("[data-metric]")).forEach((el) => {
        if (!(el instanceof HTMLElement)) return;
        const shouldHide = el.dataset.metric !== metricSelect.value;
        el.hidden = shouldHide;
        el.classList.toggle("hidden", shouldHide);
      });
      bindLeaderboardRows();
    };

    const createCardMarkup = (model) => {
      const name = escapeHtml(toDisplayName(model.name));
      const company = escapeHtml(
        toDisplayName(model.company_name, "Unknown provider"),
      );
      const openRouterParameters = Array.isArray(model.openrouter_supported_parameters)
        ? model.openrouter_supported_parameters
        : [];
      const openRouterInputModalities = Array.isArray(model.openrouter_input_modalities)
        ? model.openrouter_input_modalities
        : [];
      const openRouterOutputModalities = Array.isArray(model.openrouter_output_modalities)
        ? model.openrouter_output_modalities
        : [];
      const hasOpenRouterData = Boolean(model.openrouter_id);
      const hasPositiveNumber = (value) => {
        const num = Number(value);
        return Number.isFinite(num) && num > 0;
      };
      const pricesAreClose = (first, second) => {
        if (!hasPositiveNumber(first) || !hasPositiveNumber(second)) return false;
        return Math.abs(Number(first) - Number(second)) < 0.001;
      };
      const hasOpenRouterPrice =
        hasPositiveNumber(model.openrouter_prompt_price_1m) ||
        hasPositiveNumber(model.openrouter_completion_price_1m);
      const openRouterPriceMatchesAa =
        pricesAreClose(model.price_1m_input_tokens, model.openrouter_prompt_price_1m) &&
        pricesAreClose(model.price_1m_output_tokens, model.openrouter_completion_price_1m);
      const showOpenRouterPricing = hasOpenRouterPrice && !openRouterPriceMatchesAa;
      const effectiveContextLength =
        model.openrouter_context_length || model.context_window;
      const dataSourceBadge = hasOpenRouterData ? "AA + OR" : "AA";
      const openRouterCaps =
        [
          openRouterParameters.includes("tools") ? "Tools" : null,
          openRouterInputModalities.includes("image") ? "Vision" : null,
          openRouterOutputModalities.includes("image") ? "Image out" : null,
        ]
          .filter(Boolean)
          .join(", ") || "Text";
      const catalogMarkup = hasOpenRouterData
        ? `
          <section class="card-metric-panel mt-2 px-3 py-2">
            <div class="text-[0.55rem] text-muted">OpenRouter catalog</div>
            <dl class="mt-1.5 grid grid-cols-2 gap-x-4 gap-y-1 text-[0.65rem] text-text">
              <div class="flex items-center justify-between gap-2"><dt class="text-subtle">Tools</dt><dd class="font-bold">${openRouterParameters.includes("tools") ? "Yes" : "No"}</dd></div>
              <div class="flex items-center justify-between gap-2"><dt class="text-subtle">Route</dt><dd class="font-bold">${model.openrouter_is_free ? "Free" : "Paid"}</dd></div>
              ${
                showOpenRouterPricing
                  ? `<div class="flex items-center justify-between gap-2"><dt class="text-subtle">OR input</dt><dd class="font-bold">${formatPrice(model.openrouter_prompt_price_1m, 3)}</dd></div>
                     <div class="flex items-center justify-between gap-2"><dt class="text-subtle">OR output</dt><dd class="font-bold">${formatPrice(model.openrouter_completion_price_1m, 3)}</dd></div>`
                  : ""
              }
              <div class="col-span-2 flex items-center justify-between gap-3"><dt class="text-subtle">Modalities</dt><dd class="min-w-0 truncate font-bold">${escapeHtml(openRouterInputModalities.join(", ") || "text")} -&gt; ${escapeHtml(openRouterOutputModalities.join(", ") || "text")}</dd></div>
              <div class="col-span-2 flex items-center justify-between gap-3"><dt class="text-subtle">Capabilities</dt><dd class="min-w-0 truncate font-bold">${escapeHtml(openRouterCaps)}</dd></div>
            </dl>
          </section>
        `
        : "";
      return `
        <div
          data-model-card
          data-model-id="${escapeHtml(model.id)}"
          data-model-json="${escapeHtml(JSON.stringify(model))}"
          data-name="${escapeHtml(String(model.name ?? "").toLowerCase())}"
          data-company="${escapeHtml(String(model.company_name ?? "").toLowerCase())}"
          data-mmlu="${Number(model.mmlu_pro) || 0}"
          data-gpqa="${Number(model.gpqa) || 0}"
          data-hle="${Number(model.hle) || 0}"
          data-aime="${Number(model.aime) || 0}"
          data-input-price="${Number(model.price_1m_input_tokens) || 0}"
          data-output-price="${Number(model.price_1m_output_tokens) || 0}"
          data-tps="${Number(model.median_output_tokens_per_second) || 0}"
          class="model-card brutalist-card group border border-highlight-med bg-surface px-4 py-4 text-sm stagger-item tilt-card"
        >
          <header class="flex items-start justify-between gap-2">
            <div class="min-w-0">
              <h3 class="truncate text-sm font-semibold text-text group-hover:text-foam transition-colors" title="${name}">${name}</h3>
              <p class="mt-0.5 text-xs text-subtle">${company}</p>
            </div>
            <div class="source-strip flex-shrink-0" title="Data coverage">
              <span>${dataSourceBadge}</span>
            </div>
          </header>
          <div class="mt-3 grid gap-2 text-[0.7rem] text-subtle sm:grid-cols-2 xl:grid-cols-3">
            <section class="card-metric-panel px-3 py-2">
              <div class="text-[0.55rem] text-muted">Pricing</div>
              <dl class="mt-1.5 space-y-0.5 text-text text-[0.65rem]">
                <div class="flex items-center justify-between"><dt>Input</dt><dd class="font-semibold">${formatPrice(model.price_1m_input_tokens, 3)}</dd></div>
                <div class="flex items-center justify-between"><dt>Output</dt><dd class="font-semibold">${formatPrice(model.price_1m_output_tokens, 3)}</dd></div>
                <div class="flex items-center justify-between"><dt>Blended</dt><dd class="font-semibold">${formatPrice(model.price_1m_blended_3_to_1, 3)}</dd></div>
              </dl>
            </section>
            <section class="card-metric-panel px-3 py-2">
              <div class="text-[0.55rem] text-muted">Performance</div>
              <dl class="mt-1.5 space-y-0.5 text-text text-[0.65rem]">
                <div class="flex items-center justify-between"><dt>TPS</dt><dd class="font-semibold">${formatTps(model.median_output_tokens_per_second)}</dd></div>
                <div class="flex items-center justify-between"><dt>TTFT token</dt><dd class="font-semibold">${formatTtft(model.median_time_to_first_token_seconds)}</dd></div>
                <div class="flex items-center justify-between"><dt>TTFT answer</dt><dd class="font-semibold">${formatTtft(model.median_time_to_first_answer_token)}</dd></div>
              </dl>
            </section>
            <section class="card-metric-panel px-3 py-2">
              <div class="text-[0.55rem] text-muted">Specs</div>
              <dl class="mt-1.5 space-y-0.5 text-text text-[0.65rem]">
                <div class="flex items-center justify-between"><dt>Context</dt><dd class="font-semibold">${formatContextLength(effectiveContextLength)}</dd></div>
                <div class="flex items-center justify-between"><dt>Max output</dt><dd class="font-semibold">${formatContextLength(model.max_output_tokens)}</dd></div>
                <div class="flex items-center justify-between"><dt>Source</dt><dd class="font-semibold">${dataSourceBadge}</dd></div>
              </dl>
            </section>
          </div>
          <section class="card-metric-panel mt-2 px-3 py-2">
            <div class="text-[0.55rem] text-muted">Benchmarks</div>
            <div class="mt-1.5 grid grid-cols-2 gap-x-4 gap-y-1 text-[0.65rem]">
              <div class="flex items-center justify-between"><span class="text-subtle">MMLU</span><span class="font-semibold ${getScoreClass(model.mmlu_pro)}">${formatScore(model.mmlu_pro)}</span></div>
              <div class="flex items-center justify-between"><span class="text-subtle">GPQA</span><span class="font-semibold ${getScoreClass(model.gpqa)}">${formatScore(model.gpqa)}</span></div>
              <div class="flex items-center justify-between"><span class="text-subtle">HLE</span><span class="font-semibold ${getScoreClass(model.hle)}">${formatScore(model.hle)}</span></div>
              <div class="flex items-center justify-between"><span class="text-subtle">AIME</span><span class="font-semibold ${getScoreClass(model.aime)}">${formatScore(model.aime)}</span></div>
              <div class="flex items-center justify-between"><span class="text-subtle">LiveCodeBench</span><span class="font-semibold ${getScoreClass(model.livecodebench)}">${formatScore(model.livecodebench)}</span></div>
              <div class="flex items-center justify-between"><span class="text-subtle">SciCode</span><span class="font-semibold ${getScoreClass(model.scicode)}">${formatScore(model.scicode)}</span></div>
              <div class="flex items-center justify-between"><span class="text-subtle">Math 500</span><span class="font-semibold ${getScoreClass(model.math_500)}">${formatScore(model.math_500)}</span></div>
            </div>
          </section>
          <section class="card-metric-panel mt-2 px-3 py-2">
            <div class="text-[0.55rem] text-muted">AA indexes</div>
            <div class="mt-1.5 grid grid-cols-3 gap-1.5 text-center text-[0.65rem]">
              <div class="border border-highlight-med bg-overlay px-1.5 py-1.5"><div class="text-[0.5rem] uppercase text-muted">Intelligence</div><div class="font-bold ${getScoreClass(model.aa_intelligence_index)}">${formatScore(model.aa_intelligence_index)}</div></div>
              <div class="border border-highlight-med bg-overlay px-1.5 py-1.5"><div class="text-[0.5rem] uppercase text-muted">Coding</div><div class="font-bold ${getScoreClass(model.aa_coding_index)}">${formatScore(model.aa_coding_index)}</div></div>
              <div class="border border-highlight-med bg-overlay px-1.5 py-1.5"><div class="text-[0.5rem] uppercase text-muted">Math</div><div class="font-bold ${getScoreClass(model.aa_math_index)}">${formatScore(model.aa_math_index)}</div></div>
            </div>
          </section>
          ${catalogMarkup}
        </div>
      `;
    };

    const createTableRowMarkup = (model) => `
      <tr
        class="cursor-pointer transition-colors hover:bg-highlight-low/50"
        data-table-row
        tabindex="0"
        role="button"
        aria-label="Open ${escapeHtml(toDisplayName(model.name))} details"
        data-model-json="${escapeHtml(JSON.stringify(model))}"
        data-name="${escapeHtml(String(model.name ?? "").toLowerCase())}"
        data-company="${escapeHtml(String(model.company_name ?? "").toLowerCase())}"
        data-mmlu="${Number(model.mmlu_pro) || 0}"
        data-gpqa="${Number(model.gpqa) || 0}"
        data-input-price="${Number(model.price_1m_input_tokens) || 0}"
        data-output-price="${Number(model.price_1m_output_tokens) || 0}"
        data-tps="${Number(model.median_output_tokens_per_second) || 0}"
      >
        <th scope="row" class="px-4 py-3 font-medium text-text">${escapeHtml(toDisplayName(model.name))}</th>
        <td class="px-4 py-3 text-subtle">${escapeHtml(toDisplayName(model.company_name, "-"))}</td>
        <td class="px-4 py-3 text-right font-mono text-text">${formatContextLength(model.openrouter_context_length)}</td>
        <td class="px-4 py-3 text-right font-mono text-text">${formatPrice(model.price_1m_input_tokens, 3)}</td>
        <td class="px-4 py-3 text-right font-mono text-text">${formatPrice(model.price_1m_output_tokens, 3)}</td>
        <td class="px-4 py-3 text-right font-semibold ${getScoreClass(model.mmlu_pro)}">${formatScore(model.mmlu_pro)}</td>
        <td class="px-4 py-3 text-right font-semibold ${getScoreClass(model.gpqa)}">${formatScore(model.gpqa)}</td>
        <td class="px-4 py-3 text-right text-text">${formatTps(model.median_output_tokens_per_second)}</td>
      </tr>
    `;

    const openModelDrawerFromElement = (element) => {
      const modelJson = element?.dataset?.modelJson;
      if (!modelJson) return;
      try {
        const model = JSON.parse(modelJson);
        window.dispatchEvent(new CustomEvent("open-model-drawer", { detail: model }));
      } catch (error) {
        console.warn("Failed to parse model payload", error);
      }
    };

    const bindCardFocus = () => {
      getCards().forEach((card) => {
        card.setAttribute("tabindex", "0");
        card.setAttribute("role", "button");
        card.setAttribute("aria-label", "Open model details");
        card.addEventListener("focus", () => {
          focusedCardIndex = getVisibleCards().indexOf(card);
        });
        if (card.dataset.drawerBound === "true") return;
        card.dataset.drawerBound = "true";
        card.addEventListener("click", () => openModelDrawerFromElement(card));
        card.addEventListener("keydown", (event) => {
          if (event.key !== "Enter" && event.key !== " ") return;
          event.preventDefault();
          openModelDrawerFromElement(card);
        });
      });
    };

    const bindTableRows = () => {
      getTableRows().forEach((row) => {
        if (row.dataset.drawerBound === "true") return;
        row.dataset.drawerBound = "true";
        row.addEventListener("click", () => openModelDrawerFromElement(row));
        row.addEventListener("keydown", (event) => {
          if (event.key !== "Enter" && event.key !== " ") return;
          event.preventDefault();
          openModelDrawerFromElement(row);
        });
      });
    };

    const openLeaderboardRow = (row) => {
      if (row.dataset.modelJson) {
        openModelDrawerFromElement(row);
        return;
      }
      const compareUrl = row.dataset.compareUrl;
      if (compareUrl) window.location.href = compareUrl;
    };

    const bindLeaderboardRows = () => {
      document.querySelectorAll("[data-leaderboard-row]").forEach((row) => {
        if (!(row instanceof HTMLElement)) return;
        if (row.dataset.leaderboardBound === "true") return;
        row.dataset.leaderboardBound = "true";
        row.addEventListener("click", () => openLeaderboardRow(row));
        row.addEventListener("keydown", (event) => {
          if (event.key !== "Enter" && event.key !== " ") return;
          event.preventDefault();
          openLeaderboardRow(row);
        });
      });
    };

    const updateVisibility = () => {
      let visible = 0;
      getCards().forEach((card) => {
        const match = card.dataset.match === "true";
        if (match && visible < currentVisible) {
          card.style.display = "";
          visible += 1;
        } else {
          card.style.display = "none";
        }
      });

      if (visibleCountEl) visibleCountEl.textContent = String(visible);
      if (loadMoreBtn) loadMoreBtn.hidden = visible >= matchedTotal;
      if (grid && currentView === "cards")
        grid.style.display = matchedTotal === 0 ? "none" : "";
      if (emptyState) emptyState.classList.toggle("hidden", matchedTotal > 0);
    };

    const applyTableSearch = () => {
      const q = (searchInput?.value || "").toLowerCase().trim();
      getTableRows().forEach((row) => {
        const name = row.dataset.name || "";
        const company = row.dataset.company || "";
        row.style.display =
          !q || name.includes(q) || company.includes(q) ? "" : "none";
      });
    };

    const applySearch = (resetVisible = false) => {
      if (resetVisible) currentVisible = PAGE_SIZE;
      const q = (searchInput?.value || "").toLowerCase().trim();
      matchedTotal = 0;

      getCards().forEach((card) => {
        const name = card.dataset.name || "";
        const company = card.dataset.company || "";
        const match = !q || name.includes(q) || company.includes(q);
        card.dataset.match = match ? "true" : "false";
        if (match) matchedTotal += 1;
      });

      updateVisibility();
      if (currentView === "table") applyTableSearch();
    };

    const sortCards = () => {
      if (!grid) return;
      const metric = sortSelect?.value || "mmlu";
      const direction = sortDirectionSelect?.value || "desc";
      const attr = sortAttrMap[metric] ?? "mmlu";

      const cards = getCards();
      cards.sort((a, b) => {
        const valA = Number(a.dataset[attr]) || 0;
        const valB = Number(b.dataset[attr]) || 0;
        if (valA === valB) return 0;
        return direction === "desc" ? valB - valA : valA - valB;
      });
      cards.forEach((card) => grid.appendChild(card));

      const rows = getTableRows();
      rows.sort((a, b) => {
        const valA = Number(a.dataset[attr]) || 0;
        const valB = Number(b.dataset[attr]) || 0;
        if (valA === valB) return 0;
        return direction === "desc" ? valB - valA : valA - valB;
      });
      rows.forEach((row) => tableBody?.appendChild(row));

      applySearch(true);
    };

    const setView = (view) => {
      currentView = view;
      if (view === "cards") {
        if (grid) grid.style.display = matchedTotal === 0 ? "none" : "";
        tableContainer?.classList.add("hidden");
        viewCardsBtn?.classList.add("active");
        viewCardsBtn?.setAttribute("aria-pressed", "true");
        viewTableBtn?.classList.remove("active");
        viewTableBtn?.setAttribute("aria-pressed", "false");
        if (loadMoreBtn) loadMoreBtn.style.display = "";
      } else {
        if (grid) grid.style.display = "none";
        tableContainer?.classList.remove("hidden");
        viewCardsBtn?.classList.remove("active");
        viewCardsBtn?.setAttribute("aria-pressed", "false");
        viewTableBtn?.classList.add("active");
        viewTableBtn?.setAttribute("aria-pressed", "true");
        if (loadMoreBtn) loadMoreBtn.style.display = "none";
        applyTableSearch();
      }
    };

    const renderModels = (models) => {
      if (!grid || !tableBody) return;
      grid.innerHTML = models.map(createCardMarkup).join("");
      tableBody.innerHTML = models.map(createTableRowMarkup).join("");
      bindCardFocus();
      bindTableRows();
      sortCards();
      setView(currentView);
    };

    metricSelect?.addEventListener("change", () => {
      const metric = metricSelect.value;
      updateLeaderboardCompareLink();
      Array.from(document.querySelectorAll("[data-metric]")).forEach((el) => {
        if (!(el instanceof HTMLElement)) return;
        const shouldHide = el.dataset.metric !== metric;
        el.hidden = shouldHide;
        el.classList.toggle("hidden", shouldHide);
      });
    });

    openRouterRankSelect?.addEventListener("change", () => {
      renderOpenRouterProviderLeaderboard();
    });

    loadMoreBtn?.addEventListener("click", () => {
      currentVisible = Math.min(currentVisible + PAGE_SIZE, matchedTotal);
      updateVisibility();
    });

    sortSelect?.addEventListener("change", sortCards);
    sortDirectionSelect?.addEventListener("change", sortCards);
    searchInput?.addEventListener("input", () => applySearch(true));
    viewCardsBtn?.addEventListener("click", () => setView("cards"));
    viewTableBtn?.addEventListener("click", () => setView("table"));

    document.addEventListener("keydown", (event) => {
      const visibleCards = getVisibleCards();
      if (!visibleCards.length) return;
      if (event.key !== "ArrowDown" && event.key !== "ArrowUp") return;
      const active = document.activeElement;
      const isCardFocused =
        active instanceof HTMLElement &&
        active.matches("[data-model-card]");
      if (!isCardFocused) return;
      event.preventDefault();
      const delta = event.key === "ArrowDown" ? 1 : -1;
      focusedCardIndex = Math.max(
        0,
        Math.min(visibleCards.length - 1, focusedCardIndex + delta),
      );
      visibleCards[focusedCardIndex]?.focus();
    });

    bindCardFocus();
    bindTableRows();
    bindLeaderboardRows();
    renderOpenRouterProviderLeaderboard();
    updateLeaderboardCompareLink();
    applySearch(true);

    window.addEventListener("aistats:live-snapshot", (event) => {
      const snapshot = event.detail;
      if (!snapshot) return;

      const liveModels = enrichWithOpenRouter(getValidModels(snapshot.aaModels ?? []));
      const epochBenchmarks = snapshot.epochBenchmarks ?? [];
      const epochRuns = snapshot.epochRuns ?? [];

      updateModelCounts(liveModels);
      updateSummaryStats(liveModels);
      updateTopStrip(liveModels, snapshot.epochModels ?? [], epochRuns);
      renderOpenRouterProviderLeaderboard();
      renderLeaderboard(liveModels, epochBenchmarks, epochRuns);
      renderModels(liveModels);
    });
  }
</script>

<script>
  import { fetchLiveSnapshot } from "../lib/live-data";

  const scheduleLiveRefresh = () => {
    const run = async () => {
      const snapshot = await fetchLiveSnapshot({ includeEpoch: true });
      if (!snapshot) return;
      window.dispatchEvent(
        new CustomEvent("aistats:live-snapshot", { detail: snapshot }),
      );
    };

    if ("requestIdleCallback" in window) {
      window.requestIdleCallback(
        () => {
          void run();
        },
        { timeout: 5000 },
      );
    } else {
      setTimeout(() => {
        void run();
      }, 2500);
    }
  };

  if (document.readyState === "complete") {
    scheduleLiveRefresh();
  } else {
    window.addEventListener("load", scheduleLiveRefresh, { once: true });
  }
</script>
