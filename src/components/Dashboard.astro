      </header>

      <div
        class="sticky top-[56px] z-20 border border-highlight-low/70 bg-overlay px-4 py-3 flex flex-col gap-3 md:flex-row md:items-start md:justify-between"
      >
        <div class="w-full md:max-w-xs">
          <label
            for="model-search"
            class="block text-xs font-medium text-subtle"
          >
            Search models
          </label>
          <input
