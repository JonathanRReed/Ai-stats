      <div class="grid gap-3 md:grid-cols-2 stagger-container" id="models-grid">
        {initialModels.map((model: any) => <ModelCard model={model} />)}
      </div>

      <!-- Table view (hidden by default) -->
      <div id="models-table-container" class="hidden overflow-x-auto rounded-lg border border-highlight-low bg-surface/70">
        <table class="w-full min-w-[900px] text-left text-sm">
          <thead
            class="border-b border-highlight-med bg-overlay/50 text-xs uppercase text-subtle"
          >
            <tr>
              <th scope="col" class="px-4 py-3 font-semibold">Model</th>
              <th scope="col" class="px-4 py-3 font-semibold">Provider</th>
              <th scope="col" class="px-4 py-3 font-semibold text-right">Context</th>
              <th scope="col" class="px-4 py-3 font-semibold text-right">Input</th>
