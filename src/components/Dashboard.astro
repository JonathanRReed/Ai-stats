---
import {
  getModels,
  getHydratedEpochModels,
  getEpochBenchmarks,
  getEpochBenchmarkRuns,
  getOpenRouterModels,
  enrichModelsWithOpenRouterData,
} from "../lib/supabase";
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import ScrollToTop from "./ScrollToTop.astro";
import { formatScore, formatPrice } from "../lib/format-utils";
import ModelCard from "./ModelCard.astro";

const [baseModels, epochBenchmarks, epochRuns, openRouterModels] =
  await Promise.all([
    getModels(),
    getEpochBenchmarks(),
    getEpochBenchmarkRuns(),
    getOpenRouterModels(),
  ]);
const epochModels = await getHydratedEpochModels(epochRuns);
const models = enrichModelsWithOpenRouterData(baseModels, openRouterModels);

// Key epoch benchmarks to display
const keyEpochBenchmarks = [
  "gpqa_diamond",
  "frontiermath",
  "swe_bench_verified",
  "math_level_5",
  "arc_agi_external",
  "mmlu_external",
  "gsm8k_external",
  "aider_polyglot_external",
];

// Get benchmark name mapping
const epochBenchmarkNames: Record<string, string> = {};
epochBenchmarks.forEach((b) => {
  epochBenchmarkNames[b.slug] = b.name;
});

const AA_TOP_AVERAGE_KEYS = [
  "mmlu_pro",
  "gpqa",
  "hle",
  "aime",
  "scicode",
  "math_500",
  "livecodebench",
  "aa_math_index",
  "aa_coding_index",
  "aa_intelligence_index",
] as const;

const toPercentScore = (value: number | null | undefined): number | null => {
  const score = Number(value);
  if (!Number.isFinite(score) || score <= 0) return null;
  return score <= 1 ? score * 100 : score;
};

const averageScore = (values: Array<number | null | undefined>): number | null => {
  const normalized = values
    .map((value) => toPercentScore(value))
    .filter((value): value is number => value !== null);
  if (!normalized.length) return null;
  return normalized.reduce((sum, value) => sum + value, 0) / normalized.length;
};

const normalizeModelVersion = (value: string | null | undefined): string =>
  String(value || "")
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, " ")
    .trim();

const buildEpochModelAliases = (model: {
  model_version?: string | null;
  model_name?: string | null;
  display_name?: string | null;
}): Set<string> => {
  const aliases = new Set<string>();
  [model.model_version, model.model_name, model.display_name].forEach((value) => {
    const normalized = normalizeModelVersion(value);
    if (!normalized) return;
    aliases.add(normalized);
    aliases.add(normalized.replace(/\s+/g, ""));
  });
  return aliases;
};

const getEpochAverageForModel = (model: {
  model_version?: string | null;
  model_name?: string | null;
  display_name?: string | null;
}): number | null => {
  const aliases = buildEpochModelAliases(model);
  if (!aliases.size) return null;

  const scores = epochRuns
    .filter(
      (run) => {
        const normalizedRun = normalizeModelVersion(run.model_version);
        if (!normalizedRun || Number(run.score) <= 0) return false;
        return (
          aliases.has(normalizedRun) ||
          aliases.has(normalizedRun.replace(/\s+/g, ""))
        );
      },
    )
    .map((run) => toPercentScore(Number(run.score)))
    .filter((score): score is number => score !== null);
  if (!scores.length) return null;
  return scores.reduce((sum, score) => sum + score, 0) / scores.length;
};

// Top epoch model by ECI score
const topEciModel =
  [...epochModels]
    .filter((m) => Number(m.eci_score) > 0)
    .sort((a, b) => Number(b.eci_score) - Number(a.eci_score))[0] ?? null;
const topEciAverageScore = topEciModel
  ? getEpochAverageForModel(topEciModel)
  : null;

const validModels = models.filter((model: any) => {
  const inputPrice = Number(model.price_1m_input_tokens);
  const outputPrice = Number(model.price_1m_output_tokens);
  return inputPrice > 0 && outputPrice > 0;
});

const totalModels = validModels.length;
const INITIAL_VISIBLE_MODELS = Math.min(20, totalModels);
const initialModels = validModels.slice(0, INITIAL_VISIBLE_MODELS);
const avgInputPrice =
  validModels.reduce(
    (sum: number, m: any) => sum + Number(m.price_1m_input_tokens),
    0,
  ) / (totalModels || 1);
const avgOutputPrice =
  validModels.reduce(
    (sum: number, m: any) => sum + Number(m.price_1m_output_tokens),
    0,
  ) / (totalModels || 1);

// Combined benchmark configs - AA benchmarks first, then Epoch benchmarks
const benchmarkConfigs = [
  // AA Benchmarks
  { key: "mmlu_pro", label: "MMLU Pro", source: "aa" },
  { key: "gpqa", label: "GPQA", source: "aa" },
  { key: "hle", label: "HLE", source: "aa" },
  { key: "aime", label: "AIME", source: "aa" },
  { key: "scicode", label: "SciCode", source: "aa" },
  { key: "math_500", label: "Math 500", source: "aa" },
  { key: "livecodebench", label: "LiveCodeBench", source: "aa" },
  { key: "aa_math_index", label: "AA Math Index", source: "aa" },
  { key: "aa_coding_index", label: "AA Coding Index", source: "aa" },
  {
    key: "aa_intelligence_index",
    label: "AA Intelligence Index",
    source: "aa",
  },
  // Epoch Benchmarks
  ...keyEpochBenchmarks.map((slug) => ({
    key: `epoch_${slug}`,
    label: `${epochBenchmarkNames[slug] || slug} (Epoch)`,
    source: "epoch" as const,
  })),
];

// Build top models for AA benchmarks
const topByBenchmark: Record<string, any[]> = {};

// AA benchmarks - from validModels
benchmarkConfigs
  .filter((c) => c.source === "aa")
  .forEach(({ key }) => {
    const list = [...validModels]
      .filter((m: any) => m[key] && Number(m[key]) > 0)
      .sort((a: any, b: any) => Number(b[key]) - Number(a[key]))
      .slice(0, 5);
    topByBenchmark[key] = list;
  });

// Epoch benchmarks - from epochRuns
keyEpochBenchmarks.forEach((slug) => {
  const runs = epochRuns
    .filter((r) => r.benchmark_slug === slug && r.score !== null)
    .sort((a, b) => (b.score ?? 0) - (a.score ?? 0))
    .slice(0, 5)
    .map((r) => ({
      name: r.model_version.replace(/_/g, " ").replace(/-/g, " "),
      company_name: r.organization,
      score: r.score,
      isEpoch: true,
    }));
  topByBenchmark[`epoch_${slug}`] = runs;
});

const topAaAverageModel =
  [...validModels]
    .map((model: any) => ({
      model,
      avgScore: averageScore(
        AA_TOP_AVERAGE_KEYS.map((metricKey) => Number(model[metricKey])),
      ),
    }))
    .filter((entry) => entry.avgScore !== null)
    .sort((a, b) => Number(b.avgScore) - Number(a.avgScore))[0] ??
  null;

const cheapestBlendedModel =
  [...validModels]
    .filter((m: any) => Number(m.price_1m_blended_3_to_1) > 0)
    .sort(
      (a: any, b: any) =>
        Number(a.price_1m_blended_3_to_1) - Number(b.price_1m_blended_3_to_1),
    )[0] ?? null;

const openRouterToolModels = openRouterModels.filter((model) =>
  model.supported_parameters.includes("tools"),
);
const openRouterVisionModels = openRouterModels.filter((model) =>
  model.input_modalities.includes("image"),
);
const openRouterLongContextModels = [...openRouterModels]
  .filter((model) => Number(model.context_length) > 0)
  .sort((a, b) => Number(b.context_length) - Number(a.context_length));
const openRouterProviderSummary = Object.values(
  openRouterModels.reduce(
    (summary, model) => {
      const provider = model.author_slug ?? "unknown";
      if (!summary[provider]) {
        summary[provider] = {
          provider,
          total: 0,
          tools: 0,
          vision: 0,
          maxContext: 0,
        };
      }
      summary[provider].total += 1;
      if (model.supported_parameters.includes("tools")) {
        summary[provider].tools += 1;
      }
      if (model.input_modalities.includes("image")) {
        summary[provider].vision += 1;
      }
      summary[provider].maxContext = Math.max(
        summary[provider].maxContext,
        Number(model.context_length) || 0,
      );
      return summary;
    },
    {} as Record<
      string,
      {
        provider: string;
        total: number;
        tools: number;
        vision: number;
        maxContext: number;
      }
    >,
  ),
)
  .sort((a, b) => b.total - a.total)
  .slice(0, 6);

const openRouterRankOptions = [
  { key: "catalog", label: "Catalog coverage" },
  { key: "tools", label: "Tool-ready routes" },
  { key: "vision", label: "Vision coverage" },
  { key: "context", label: "Max context" },
  { key: "input_price", label: "Lowest input price" },
  { key: "output_price", label: "Lowest output price" },
] as const;

const clientOpenRouterModels = openRouterModels.map((model) => ({
  openrouter_id: model.openrouter_id,
  canonical_slug: model.canonical_slug,
  author_slug: model.author_slug,
  model_slug: model.model_slug,
  name: model.name,
  context_length: model.context_length,
  prompt_price_1m: model.prompt_price_1m,
  completion_price_1m: model.completion_price_1m,
  supported_parameters: model.supported_parameters,
  input_modalities: model.input_modalities,
  output_modalities: model.output_modalities,
  is_free: model.is_free,
}));

const formatContextLength = (value: number | null | undefined): string => {
  const num = Number(value);
  if (!Number.isFinite(num) || num <= 0) return "-";
  if (num >= 1_000_000) {
    return `${(num / 1_000_000).toFixed(num % 1_000_000 === 0 ? 0 : 1)}M`;
  }
  if (num >= 1_000) {
    return `${Math.round(num / 1_000)}K`;
  }
  return String(num);
};

const formatOpenRouterPrice = (
  value: number | null | undefined,
  decimals = 3,
): string => {
  const num = Number(value);
  if (!Number.isFinite(num) || num < 0) return "-";
  return formatPrice(num, decimals);
};

// Helper for score coloring
function getScoreClass(score: number | null | undefined): string {
  if (!score || score <= 0) return "score-none";
  const pct = score <= 1 ? score * 100 : score;
  if (pct >= 80) return "score-high";
  if (pct >= 60) return "score-mid";
  if (pct >= 40) return "score-low";
  return "score-poor";
}
---

<div class="site-shell min-h-screen bg-base text-text">
  <Header currentPage="dashboard" />

  <main
    class="telemetry-main mx-auto flex w-full max-w-7xl flex-col gap-14 px-4 pb-24 pt-10 md:gap-16 md:px-6 md:pt-16"
  >
    <h1 class="sr-only">AI model pricing and benchmark dashboard</h1>
    <section
      aria-label="Operational metrics"
      class="telemetry-bento grid-flow-dense fade-in-section stagger-container"
    >
      <article class="bento-cell stagger-item">
        <span class="console-label">Tracked models</span>
        <data id="hero-model-count" value={totalModels}>{totalModels}</data>
        <p>Priced models from the Artificial Analysis feed.</p>
      </article>
      <article class="bento-cell stagger-item">
        <span class="console-label">AA average leader</span>
        <output id="top-mmlu-name">
          {topAaAverageModel ? topAaAverageModel.model.name : "-"}
        </output>
        <samp id="top-mmlu-score">
          {
            topAaAverageModel
              ? `${formatScore(topAaAverageModel.avgScore)} avg`
              : "N/A"
          }
        </samp>
      </article>
      <article class="bento-cell stagger-item">
        <span class="console-label">Cheapest blended</span>
        <output id="cheapest-blended-name">
          {cheapestBlendedModel ? cheapestBlendedModel.name : "-"}
        </output>
        <samp id="cheapest-blended-price">
          {
            cheapestBlendedModel
              ? formatPrice(
                  Number(cheapestBlendedModel.price_1m_blended_3_to_1) || 0,
                  3,
                )
              : ""
          }
        </samp>
      </article>
      <article class="bento-cell stagger-item">
        <span class="console-label">Epoch signal</span>
        <output id="top-eci-name">
          {
            topEciModel
              ? topEciModel.display_name || topEciModel.model_name
              : "-"
          }
        </output>
        <samp id="top-eci-score">
          {
            topEciAverageScore !== null
              ? `${topEciAverageScore.toFixed(1)}% avg`
              : topEciModel && Number(topEciModel.eci_score) > 0
                ? `${Number(topEciModel.eci_score).toFixed(1)} ECI`
                : "N/A"
          }
        </samp>
      </article>
      <article class="bento-cell stagger-item">
        <span class="console-label">Epoch coverage</span>
        <data id="epoch-models-count" value={epochModels.length}>
          {epochModels.length}
        </data>
        <p><span id="epoch-runs-count">{epochRuns.length} benchmark runs</span></p>
      </article>
      <article class="bento-cell stagger-item">
        <span class="console-label">Token averages</span>
        <div class="metric-pair">
          <span>
            <small>Input</small>
            <data id="summary-avg-input">{formatPrice(avgInputPrice, 3)}</data>
          </span>
          <span>
            <small>Output</small>
            <data id="summary-avg-output">{formatPrice(avgOutputPrice, 3)}</data>
          </span>
        </div>
        <p>Mean price per 1M tokens across priced models.</p>
      </article>
    </section>

    {
      openRouterModels.length ? (
        <section
          aria-label="OpenRouter collections"
          class="openrouter-panel fade-in-section"
        >
          <header class="openrouter-header">
            <div>
              <p class="console-label">OpenRouter source</p>
              <h2>Public catalog data</h2>
            </div>
            <div class="openrouter-actions">
              <label for="openrouter-rank-metric">Rank by</label>
              <div class="openrouter-select-wrap">
                <select id="openrouter-rank-metric" class="openrouter-rank-select">
                  {openRouterRankOptions.map((option) => (
                    <option value={option.key}>{option.label}</option>
                  ))}
                </select>
              </div>
              <a
                href="https://openrouter.ai/rankings/"
                target="_blank"
                rel="noopener noreferrer"
                class="toolbar-control px-3 py-2 text-[0.7rem] font-bold uppercase text-text"
              >
                View rankings
              </a>
            </div>
          </header>
          <div class="openrouter-grid">
            <div class="openrouter-stats" aria-label="OpenRouter catalog totals">
              <dl>
                <div>
                  <dt>Total catalog</dt>
                  <dd>{openRouterModels.length}</dd>
                </div>
                <div>
                  <dt>Tool-ready</dt>
                  <dd>{openRouterToolModels.length}</dd>
                </div>
                <div>
                  <dt>Vision input</dt>
                  <dd>{openRouterVisionModels.length}</dd>
                </div>
                <div>
                  <dt>Max context</dt>
                  <dd>{formatContextLength(openRouterLongContextModels[0]?.context_length)}</dd>
                </div>
              </dl>
              <p>
                Public OpenRouter metadata for availability, modalities, context,
                and route pricing. Benchmark scores remain AA and Epoch.
              </p>
            </div>
            <div class="openrouter-table" aria-label="OpenRouter provider leaderboard">
              <div class="openrouter-table-meta">
                <span id="openrouter-board-title">Provider coverage</span>
                <small id="openrouter-board-note">OpenRouter catalog ranking</small>
              </div>
              <div class="openrouter-table-head" aria-hidden="true">
                <span>Provider</span>
                <span>Leader</span>
                <span>Score</span>
                <span>Models</span>
                <span>Max ctx</span>
              </div>
              <ul id="openrouter-provider-board">
                {openRouterProviderSummary.map((provider) => (
                  <li>
                    <button
                      type="button"
                      class="openrouter-provider-row"
                      data-openrouter-provider={provider.provider}
                      data-openrouter-provider-query={provider.provider}
                    >
                      <span class="openrouter-model" title={provider.provider}>
                        {provider.provider}
                      </span>
                      <span class="openrouter-leader">{provider.tools} tool-ready</span>
                      <span class="openrouter-score">{provider.total}</span>
                      <span>{provider.total}</span>
                      <span>{formatContextLength(provider.maxContext)}</span>
                    </button>
                  </li>
                ))}
              </ul>
            </div>
            <div class="openrouter-long-context">
              <span class="console-label">Longest context</span>
              <strong>{openRouterLongContextModels[0]?.name ?? "-"}</strong>
              <span>
                {formatContextLength(openRouterLongContextModels[0]?.context_length)}
                {" tokens"}
              </span>
              <small>
                Input {formatOpenRouterPrice(openRouterLongContextModels[0]?.prompt_price_1m)}
                {" / "}
                output {formatOpenRouterPrice(openRouterLongContextModels[0]?.completion_price_1m)}
                {" per 1M"}
              </small>
            </div>
          </div>
        </section>
      ) : null
    }

    <!-- Leaderboard -->
    <section aria-label="Leaderboard" class="space-y-4 fade-in-section">
      <div class="brutalist-card">
        <header
          class="relative z-20 flex flex-col gap-3 border-b border-highlight-low/80 px-4 py-4 md:flex-row md:items-center md:justify-between md:px-6"
        >
          <div>
            <h2 class="text-base font-semibold text-text md:text-lg">
              Leaderboard
            </h2>
            <p class="text-[0.7rem] text-subtle md:text-xs">
              Switch metrics to see different top-5 rankings.
            </p>
          </div>
          <div class="leaderboard-controls relative z-30">
            <a
              id="leaderboard-compare-link"
              href="/compare?metric=mmlu_pro"
              class="toolbar-control px-3 py-1 text-[0.7rem] font-bold uppercase text-text"
            >
              Open compare
            </a>
            <label
              for="leaderboard-metric"
              class="text-[0.7rem] font-medium text-subtle"
            >
              Metric
            </label>
            <select
              id="leaderboard-metric"
              class="toolbar-control relative z-30 pointer-events-auto px-3 py-1 text-[0.7rem] font-bold uppercase text-text active:translate-y-px"
            >
              {
                benchmarkConfigs.map(({ key, label }) => (
                  <option value={key} selected={key === "mmlu_pro"}>
                    {label}
                  </option>
                ))
              }
            </select>
          </div>
        </header>

        <div
          class="relative z-10 space-y-3 px-4 pb-4 pt-3 md:px-6 md:pb-6"
          id="leaderboard-panels"
        >
          {
            benchmarkConfigs.map(({ key, source }) => {
              const list = topByBenchmark[key] ?? [];
              if (!list.length) return null;
              const isEpoch = source === "epoch";
              // For epoch benchmarks, score is stored in model.score; for AA, it's model[key]
              const getScore = (m: any) =>
                isEpoch ? Number(m.score) || 0 : Number(m[key]) || 0;
              const maxScore = Math.max(...list.map(getScore));

              return (
                <div
                  data-metric={key}
                  class="overflow-hidden border border-highlight-low/60"
                  hidden={key !== "mmlu_pro"}
                >
                  <ul class="divide-y divide-highlight-low/40">
                    {list.map((model: any, index: number) => {
                      const score = getScore(model);
                      const barWidth =
                        maxScore > 0 ? (score / maxScore) * 100 : 0;
                      const rankColors = [
                        "bg-[rgba(230,25,25,0.18)] border-l-[var(--love)]",
                        "bg-highlight-low border-l-highlight-high",
                        "bg-highlight-low border-l-highlight-med",
                        "bg-transparent border-l-highlight-med",
                        "bg-transparent border-l-highlight-med",
                      ];

                      return (
                        <li class="relative overflow-hidden transition-colors hover:bg-highlight-low/40">
                          <button
                            type="button"
                            class="leaderboard-row relative block w-full overflow-hidden text-left"
                            data-leaderboard-row
                            data-model-json={isEpoch ? undefined : JSON.stringify(model)}
                            data-compare-url={isEpoch ? `/compare?metric=${key}&model=${encodeURIComponent(model.name ?? "")}` : undefined}
                            aria-label={isEpoch ? `Open ${model.name} in compare` : `Open ${model.name} details`}
                          >
                            {/* Background bar */}
                            <div
                              class={`pointer-events-none absolute inset-y-0 left-0 ${rankColors[index]} border-l-4`}
                              style={`width: ${barWidth}%`}
                            />

                            <div class="relative grid grid-cols-[2.5rem_1fr_auto] items-center gap-4 px-4 py-3.5">
                              {/* Rank */}
                              <div class="flex items-center justify-center">
                                {index === 0 ? (
                                  <div class="flex h-8 w-8 items-center justify-center border border-love bg-love text-sm font-bold text-white">
                                    1
                                  </div>
                                ) : index === 1 ? (
                                  <div class="flex h-8 w-8 items-center justify-center border border-highlight-high bg-highlight-low text-sm font-bold text-text">
                                    2
                                  </div>
                                ) : index === 2 ? (
                                  <div class="flex h-8 w-8 items-center justify-center border border-highlight-med bg-overlay text-sm font-bold text-text">
                                    3
                                  </div>
                                ) : (
                                  <div class="flex h-7 w-7 items-center justify-center border border-highlight-med bg-highlight-low text-xs font-semibold text-subtle">
                                    {index + 1}
                                  </div>
                                )}
                              </div>

                              {/* Model info */}
                              <div class="min-w-0">
                                <div class="flex items-center gap-2">
                                  <span
                                    class={`truncate font-semibold ${index === 0 ? "text-text" : "text-text/90"}`}
                                    title={model.name}
                                  >
                                    {model.name}
                                  </span>
                                </div>
                                <div class="mt-0.5 text-[0.7rem] text-subtle">
                                  {model.company_name ?? "Unknown provider"}
                                </div>
                              </div>

                              {/* Score */}
                              <div
                                class={`text-right font-mono text-lg font-bold ${index === 0 ? "score-high" : index < 3 ? "text-text" : "text-subtle"}`}
                              >
                                {isEpoch
                                  ? `${(score * 100).toFixed(1)}%`
                                  : formatScore(model[key])}
                              </div>
                            </div>
                          </button>
                        </li>
                      );
                    })}
                  </ul>
                </div>
              );
            })
          }
        </div>
      </div>
    </section>

    <!-- All models -->
    <section id="model-browser" aria-label="All models" class="space-y-4 fade-in-section">
      <header
        class="flex flex-col gap-2 md:flex-row md:items-baseline md:justify-between"
      >
        <div>
          <h2 class="text-lg font-semibold text-text">All models</h2>
          <p class="text-xs text-subtle">
            Search and scan every tracked model.
          </p>
        </div>
        <p class="text-xs text-subtle">
          Showing <span id="visible-model-count">{INITIAL_VISIBLE_MODELS}</span>
          of
          <span id="total-models-count">{totalModels}</span> models
        </p>
      </header>

      <div
        class="sticky top-[56px] z-20 border border-highlight-low/70 bg-overlay px-4 py-3 flex flex-col gap-3 md:flex-row md:items-start md:justify-between"
      >
        <div class="w-full md:max-w-xs">
          <label
            for="model-search"
            class="block text-xs font-medium text-subtle"
          >
            Search models
          </label>
          <input
            id="model-search"
            type="text"
            placeholder="Search by name or company..."
            class="toolbar-control mt-1 w-full px-3 py-2 text-sm font-bold text-text placeholder:text-muted placeholder:font-normal"
          />
        </div>

