---
// Scroll to top button - shows when user scrolls down
---

<button
  id="scroll-to-top"
  class="scroll-to-top"
  aria-label="Scroll to top"
  title="Back to top"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="20"
    height="20"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path d="m18 15-6-6-6 6"/>
  </svg>
</button>

<style>
.scroll-to-top {
  position: fixed;
  bottom: 1.5rem;
  right: 1.5rem;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--surface), var(--overlay));
  border: 1px solid color-mix(in srgb, var(--foam) 30%, transparent);
  color: var(--foam);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transform: translateY(10px);
  transition:
    opacity var(--dur-slow) var(--ease-smooth),
    visibility var(--dur-slow) var(--ease-smooth),
    transform var(--dur-slow) var(--ease-spring),
    var(--transition-colors),
    box-shadow var(--dur-base) var(--ease-smooth);
  /* Below the mobile-nav overlay (998) and panel (999) so it never floats over the open menu. */
  z-index: 95;
  box-shadow: var(--elev-2);
}

.scroll-to-top.visible {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}

.scroll-to-top:hover {
  background: linear-gradient(135deg, var(--overlay), var(--highlight-med));
  border-color: color-mix(in srgb, var(--foam) 50%, transparent);
  box-shadow: var(--elev-2), 0 0 0 1px color-mix(in srgb, var(--foam) 20%, transparent);
  transform: translateY(-2px);
}

.scroll-to-top:active {
  transform: translateY(0);
}

@media (prefers-reduced-motion: reduce) {
  .scroll-to-top {
    transition:
      opacity var(--dur-base) var(--ease-smooth),
      visibility var(--dur-base) var(--ease-smooth);
  }
  .scroll-to-top.visible,
  .scroll-to-top:hover,
  .scroll-to-top:active {
    transform: none;
  }
}

@media (max-width: 640px) {
  .scroll-to-top {
    bottom: 1rem;
    right: 1rem;
    width: 40px;
    height: 40px;
  }
}
</style>

<script>
  // Look up the button fresh each tick so the single window listener stays
  // valid even after ClientRouter swaps the DOM on navigation.
  function syncScrollToTop() {
    const btn = document.getElementById('scroll-to-top');
    if (btn) btn.classList.toggle('visible', window.scrollY > 400);
  }

  function initScrollToTop() {
    // Bind the global scroll listener exactly once across navigations.
    if (!document.documentElement.dataset.scrollTopBound) {
      document.documentElement.dataset.scrollTopBound = '1';
      let ticking = false;
      window.addEventListener(
        'scroll',
        () => {
          if (ticking) return;
          ticking = true;
          window.requestAnimationFrame(() => {
            syncScrollToTop();
            ticking = false;
          });
        },
        { passive: true }
      );
    }

    // Bind the click handler per-button (lives/dies with the element).
    const btn = document.getElementById('scroll-to-top');
    if (btn && !btn.dataset.clickBound) {
      btn.dataset.clickBound = '1';
      btn.addEventListener('click', () => {
        const reduce = window.matchMedia(
          '(prefers-reduced-motion: reduce)'
        ).matches;
        window.scrollTo({ top: 0, behavior: reduce ? 'auto' : 'smooth' });
      });
    }

    // Initial / post-navigation state sync.
    syncScrollToTop();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initScrollToTop);
  } else {
    initScrollToTop();
  }
  document.addEventListener('astro:page-load', initScrollToTop);
</script>
