---
import Layout from "../components/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ScrollToTop from "../components/ScrollToTop.astro";

const title = "About Jonathan Reed - AI Stats Dashboard Creator";
const description =
	"Learn about Jonathan Reed and AI Stats, a web app for comparing AI model pricing, benchmark performance, and practical tradeoffs.";
---

<Layout title={title} description={description} ogType="profile">
	<style>
		.container {
			max-width: 1280px;
			margin: 0 auto;
			padding: clamp(1.25rem, 4vw, 3.5rem);
			min-height: calc(100vh - 7rem);
			position: relative;
			z-index: 1;
		}

		.about-card {
			width: 100%;
			display: grid;
			grid-template-columns: minmax(18rem, 0.85fr) minmax(0, 1.15fr);
			gap: clamp(2rem, 4vw, 4rem);
			align-items: start;
			padding: clamp(1.5rem, 3vw, 3rem) 0;
			position: relative;
		}

		.about-card::before {
			content: "";
			position: absolute;
			inset: 0 auto auto 0;
			width: 100%;
			height: 1px;
			background: var(--border-color);
			opacity: 0.8;
		}

		.profile-image {
			width: clamp(104px, 12vw, 148px);
			height: clamp(104px, 12vw, 148px);
			border-radius: 4px; /* Brutalist shape */
			margin: 0 0 1.5rem;
			overflow: hidden;
			background: var(--surface);
			border: 1px solid var(--border-color);
			box-shadow: 0 18px 44px var(--shadow-color);
			padding: 4px;
		}

		.profile-section {
			text-align: left;
			position: sticky;
			top: 6.5rem;
			max-width: 34rem;
		}

		.profile-image img {
			width: 100%;
			height: 100%;
			object-fit: cover;
		}

		.name {
			font-size: clamp(2.15rem, 4vw, 4.25rem);
			font-weight: 800;
			margin-bottom: 1rem;
			color: var(--text);
			letter-spacing: 0;
			line-height: 1;
			max-width: 14ch;
			text-wrap: balance;
		}

		.tagline {
			font-size: clamp(0.95rem, 1.6vw, 1.1rem);
			color: var(--muted);
			margin-bottom: 0;
			font-weight: 600;
			max-width: 24rem;
			line-height: 1.45;
		}

		.project-section {
			margin: 0;
		}

		.section-title {
			font-size: clamp(1.35rem, 2.4vw, 2.4rem);
			font-weight: 800;
			margin-bottom: 1rem;
			color: var(--text);
			text-align: left;
			line-height: 1.05;
		}
		.project-info {
			padding: clamp(1rem, 2vw, 1.5rem) 0 0;
			border-top: 1px solid var(--highlight-low);
		}

		.project-info p {
			margin-bottom: 1.15rem;
			line-height: 1.65;
			color: var(--text);
			max-width: 72ch;
		}

		.project-info a {
			color: var(--pine);
			text-decoration: none;
			font-weight: 700;
			transition: color 0.1s ease;
			border-bottom: 2px solid var(--border-color);
		}

		.project-info a:hover {
			color: var(--text);
			background: var(--highlight-low);
		}

		.tech-stack {
			display: flex;
			flex-wrap: wrap;
			gap: 0.5rem;
			margin-top: 1.5rem;
			justify-content: flex-start;
		}

		.tech-tag {
			background: rgba(156, 207, 216, 0.15);
			color: #e0def4;
			padding: 0.6rem 1.2rem;
			border-radius: 4px;
			font-size: 0.9rem;
			font-weight: 600;
			border: 1px solid rgba(156, 207, 216, 0.3);
			transition:
				background 0.2s ease,
				border-color 0.2s ease;
		}

		:global(html.light) .tech-tag {
			background: rgba(40, 105, 131, 0.12);
			color: #575279;
			border: 1px solid rgba(40, 105, 131, 0.3);
		}

		@media (prefers-reduced-motion: no-preference) {
			.tech-tag:hover {
				background: rgba(156, 207, 216, 0.25);
				border-color: rgba(156, 207, 216, 0.5);
			}
		}

		@media (prefers-reduced-motion: reduce) {
			.tech-tag:hover {
				background: rgba(156, 207, 216, 0.25);
				border-color: rgba(156, 207, 216, 0.5);
			}
		}

		.links-section {
			display: grid;
			grid-template-columns: repeat(2, minmax(0, 1fr));
			justify-content: flex-start;
			gap: 0.65rem;
			margin-top: 1.5rem;
			max-width: 27rem;
		}

		.links-section .brutalist-button {
			min-height: 44px;
			justify-content: flex-start;
			padding: 0.75rem 0.9rem;
			font-size: 0.72rem;
			white-space: nowrap;
			width: 100%;
		}

		.links-section svg {
			flex: 0 0 auto;
			margin-right: 0;
		}

		.project-note {
			font-style: italic;
			color: var(--subtle);
			margin-top: 1rem;
		}

		@media (max-width: 1100px) {
			.about-card {
				grid-template-columns: minmax(17rem, 0.75fr) minmax(0, 1fr);
				gap: 2.25rem;
			}

			.name {
				font-size: clamp(2rem, 3.7vw, 3.65rem);
			}
		}

		@media (max-width: 980px) {
			.about-card {
				grid-template-columns: 1fr;
				gap: 1.75rem;
				padding: 2rem 0;
			}

			.profile-section {
				position: static;
				max-width: none;
			}

			.name {
				max-width: 18ch;
				font-size: clamp(2rem, 8vw, 3.5rem);
			}
		}

		@media (max-width: 860px) {
			.container {
				padding: 1rem;
			}

			.name {
				max-width: 12ch;
			}

			.section-title {
				font-size: 1.5rem;
			}

			.link-button {
				padding: 0.75rem 1.5rem;
				font-size: 0.9rem;
			}
		}

		@media (max-width: 520px) {
			.links-section {
				grid-template-columns: 1fr;
				max-width: none;
			}

			.name {
				max-width: 11ch;
			}
		}
	</style>
	<Header currentPage="about" />
	<main class="container">
		<div class="about-card fade-in-section">
			<div class="profile-section">
				<div class="profile-image">
					<img src="/jonathan.avif" alt="Jonathan Reed" width="1024" height="768" />
				</div>
				<h1 class="name">Hello, I'm Jonathan R Reed</h1>
				<p class="tagline">
					AI Stats is a focused tool for browsing and comparing AI model data.
				</p>

			<div class="links-section">
				<a
					href="https://jonathanrreed.com/"
					target="_blank"
					rel="noopener noreferrer"
					class="brutalist-button"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="18"
						height="18"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						class="mr-2"
						><path
							d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
						></path><rect width="4" height="12" x="2" y="9"
						></rect><circle cx="4" cy="4" r="2"></circle></svg
					>
					Portfolio
				</a>
				<a
					href="https://github.com/jonathanRReed/"
					target="_blank"
					rel="noopener noreferrer"
					class="brutalist-button"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="18"
						height="18"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						class="mr-2"
						><path
							d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
						></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg
					>
					GitHub
				</a>
				<a
					href="https://jonathanrreed.com/"
					target="_blank"
					rel="noopener noreferrer"
					class="brutalist-button"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="18"
						height="18"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						class="mr-2"
						><circle cx="12" cy="12" r="10"></circle><path
							d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"
						></path><path d="M2 12h20"></path></svg
					>
					Jonathan Reed
				</a>
				<a
					href="https://jonathanrreed.com/projects/"
					target="_blank"
					rel="noopener noreferrer"
					class="brutalist-button"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="18"
						height="18"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						class="mr-2"
						><path
							d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"
						></path></svg
					>
					All Projects
				</a>
			</div>
			</div>

			<div class="project-section">
				<h2 class="section-title">About This Project</h2>
				<div class="project-info">
					<p>
						This is a hobbyist project inspired by <a
							href="https://model-prices.vercel.app/"
							target="_blank"
							rel="noopener noreferrer"
							>Theo Browne's model prices dashboard</a
						>. It's a simple AI model comparison tool to explore model
						pricing and benchmarks with near real-time data.
					</p>
					<p>
						Pricing, Artificial Analysis benchmark scores, speed,
						and latency metrics are sourced from
						<a
							href="https://artificialanalysis.ai/"
							target="_blank"
							rel="noopener noreferrer"
						>
							Artificial Analysis
						</a>
						via their free API.
					</p>
					<p>
						Epoch benchmark runs are sourced from Epoch AI's AI
						Benchmarking Hub and are used under Creative Commons
						Attribution licensing, with Apache 2.0 licensing for
						Aider Polyglot and Terminal Bench derived subsets.
					</p>
					<p>
						Model availability, routing metadata, modalities,
						context length, and route pricing are also sourced from
						<a
							href="https://openrouter.ai/"
							target="_blank"
							rel="noopener noreferrer"
						>
							OpenRouter
						</a>
						public catalog data. OpenRouter usage rankings are treated
						as routing demand signals, not benchmark scores.
					</p>
					<p>
						The interface uses NebulaSans for its display typography.
					</p>
					<p class="project-note">
						This project is not intended for commercial use and
						serves as a learning exercise in modern web development
						and AI model analysis.
					</p>
				</div>
			</div>
		</div>
	</main>
	<Footer />
	<ScrollToTop />
</Layout>
